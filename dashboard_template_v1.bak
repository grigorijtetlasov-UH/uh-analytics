// ═══════════ UTILS ═══════════
const fmt = n => { n = Number(n)||0; if(n>=1e6) return (n/1e6).toFixed(2)+'M'; if(n>=1e3) return Math.round(n/1e3)+'K'; return Math.round(n).toString(); };
const fmtN = n => Math.round(Number(n)||0).toLocaleString('uk').replace(',','.');
const fmtK = n => fmt(n);

Chart.defaults.color = '#7b84a3';
Chart.defaults.font.family = "'DM Sans', sans-serif";
Chart.defaults.font.size = 10;
const GRID = { color:'rgba(255,255,255,0.04)' };
const TOOLTIP = { backgroundColor:'#1c2137', borderColor:'#3a4170', borderWidth:1, padding:10, titleColor:'#e4e8f7', bodyColor:'#c1c7e0' };

// ═══════════ TAB SWITCHES ═══════════
function swMain(name, btn) {
  document.querySelectorAll('.mtab').forEach(t => t.classList.remove('on'));
  document.querySelectorAll('.mpnl').forEach(p => p.classList.remove('on'));
  btn.classList.add('on');
  document.getElementById('mp-'+name).classList.add('on');
  // lazy-init charts
  if(name==='sales' && !window._salesInit) { initSalesCharts(); window._salesInit=true; }
  if(name==='marketing' && !window._mktInit) { initMktCharts(); window._mktInit=true; }
  if(name==='finance' && !window._finInit) { initFinCharts(); window._finInit=true; }
}
function swSales(name, btn) {
  document.querySelectorAll('#mp-sales .tab').forEach(t => t.classList.remove('on'));
  document.querySelectorAll('#mp-sales .pnl').forEach(p => p.classList.remove('on'));
  btn.classList.add('on');
  document.getElementById('sp-'+name).classList.add('on');
  if(name!=='all' && !window['_brand_'+name]){ renderBrand(name); window['_brand_'+name]=true; }
}

// ═══════════ BRAND PANELS (same structure as "Всі") ═══════════
const BRANDS={
  matrasroll:{name:'Matrasroll',color:'#00d68f',ch:'roll',avg:2913,prodFilter:'mattress',
    cats:[{n:'Матраци',share:0.82,m:46,mp:47,ac:3100,acp:3250},{n:'Топери',share:0.14,m:42,mp:40,ac:1900,acp:1850},{n:'Інше',share:0.04,m:30,mp:31,ac:2500,acp:2400}]},
  amebli:{name:'Amebli',color:'#a29bfe',ch:'amebli',avg:5678,prodFilter:'premium',
    cats:[{n:'Матраци',share:0.50,m:44,mp:46,ac:6200,acp:6500},{n:'Топери',share:0.18,m:40,mp:39,ac:2300,acp:2250},{n:"М'які меблі",share:0.20,m:33,mp:31,ac:24000,acp:23000},{n:'Корпусні',share:0.08,m:29,mp:30,ac:19000,acp:18500},{n:'Інше',share:0.04,m:27,mp:28,ac:8000,acp:7800}]},
  sofino:{name:'Sofino',color:'#339af0',ch:'seti',avg:5728,prodFilter:'furniture',
    cats:[{n:"М'які меблі",share:0.42,m:34,mp:32,ac:33000,acp:31000},{n:'Корпусні',share:0.40,m:28,mp:29,ac:21000,acp:20500},{n:'Матраци',share:0.13,m:43,mp:45,ac:5000,acp:5200},{n:'Інше',share:0.05,m:26,mp:27,ac:9000,acp:8800}]},
  showrooms:{name:'Шоу-руми',color:'#ffa94d',ch:'roznica',avg:18525,prodFilter:'furniture',
    cats:[{n:"М'які меблі",share:0.40,m:35,mp:33,ac:42000,acp:40000},{n:'Корпусні',share:0.35,m:30,mp:31,ac:28000,acp:27000},{n:'Матраци',share:0.20,m:45,mp:46,ac:12000,acp:12500},{n:'Інше',share:0.05,m:28,mp:29,ac:15000,acp:14500}]}
};
function _prodClass(name){
  if(/диван|крісло|ліжко|шафа|novelty|новелти|ridnetut|homefort|miromark|алтерего|voss/i.test(name))return 'furniture';
  if(/bionica|purple|chocolate|cacao|tiramisu|family|dual/i.test(name))return 'premium';
  return 'mattress';
}
function _baseName(name){
  let n=name;
  n=n.replace(/\(вак[^)]*\)/gi,'');
  n=n.replace(/\d+\s*[xх]\s*\d+(\s*см)?/gi,'');
  n=n.replace(/Ортопед\.?\s*матрац|Матрац|Тонкий матрас-топпер|Тонкий матрац-топпер|Матрас-топпер/gi,'');
  n=n.replace(/,.*$/,'');
  n=n.replace(/\s+/g,' ').trim();
  return n.split(' ').slice(0,3).join(' ')||name;
}
window._brandProd={};

function renderBrand(key){
  const b=BRANDS[key]; if(!b)return;
  const ch=CH[b.ch];
  const nd=ch.june.length;
  const dayLabels=Array.from({length:O_DIM},(_,i)=>String(i+1));
  const daily=ch.june.slice();
  const actual=daily.reduce((a,x)=>a+x,0);
  const avgD=actual/nd;
  const proj=actual+avgD*(O_DIM-nd);
  const planTotal=ch.plan, planDaily=Math.round(planTotal/O_DIM);
  const mayArr=rampDaily(ch.may), mayTot=mayArr.reduce((a,x)=>a+x,0);
  const orders=Math.round(actual/b.avg);
  const allActual=Object.values(CH).reduce((s,c)=>s+c.june.reduce((a,x)=>a+x,0),0);
  const frac=actual/allActual;
  const cats=b.cats.map(c=>({...c,rev:Math.round(actual*c.share)}));
  const catTot=cats.reduce((s,c)=>s+c.rev,0);
  let prods=D.products.filter(p=>_prodClass(p.name)===b.prodFilter);
  if(prods.length<3) prods=D.products.slice();
  window._brandProd[key]=prods;
  const P=key;

  document.getElementById('sp-'+key).innerHTML=`
    <div class="kpi-row">
      <div class="kpi c1"><div class="kl">Обсяг продажів (1–25)</div><div class="kv">${fmtK(actual)}<span class="ku">₴</span></div><div class="ks">${b.name}</div></div>
      <div class="kpi c2"><div class="kl">Замовлень</div><div class="kv">~${fmtN(orders)}</div><div class="ks">~${Math.round(orders/nd)} зам/день</div></div>
      <div class="kpi c3"><div class="kl">Середній чек</div><div class="kv">${fmtN(b.avg)}<span class="ku">₴</span></div></div>
      <div class="kpi c5"><div class="kl">Прогноз місяць</div><div class="kv" style="color:var(--g)">${fmtK(proj)}<span class="ku">₴</span></div></div>
      <div class="kpi c4"><div class="kl">Частка в компанії</div><div class="kv">${(frac*100).toFixed(0)}<span class="ku">%</span></div></div>
      <div class="kpi c6"><div class="kl">Виконання плану</div><div class="kv">${(proj/planTotal*100).toFixed(0)}<span class="ku">%</span></div></div>
    </div>
    <div class="cd"><div class="ct"><span class="dot"></span>Продажі по днях — план / факт / тренд<span class="btot">vs минулий місяць</span></div>
      <canvas id="${P}-ch-daily" style="max-height:280px"></canvas>
      <div id="${P}-summary" style="display:grid;grid-template-columns:repeat(auto-fit,minmax(135px,1fr));gap:10px;margin-top:12px"></div></div>
    <div class="cd"><div class="ct"><span class="dot" style="background:var(--b)"></span>Таблиця продажів по днях<span class="btot">1–25 червня</span></div>
      <div class="scr" style="max-height:340px"><table><thead><tr><th>День</th><th class="r">Факт ₴</th><th class="r">Замовл.</th><th class="r">Сер.чек</th><th class="r">Минулий міс. ₴</th><th class="r">Δ%</th></tr></thead><tbody id="${P}-day"></tbody></table></div></div>
    <div class="cd"><div class="ct"><span class="dot" style="background:var(--p)"></span>Продажі по категоріях — маржа vs минулий місяць</div>
      <div class="scr"><table><thead><tr><th>Категорія</th><th class="r">Виручка ₴</th><th class="r">Частка</th><th class="r">Сер.чек</th><th class="r">Маржа %</th><th class="r">Маржа мин.міс</th><th class="r">Δ маржі</th></tr></thead><tbody id="${P}-cat"></tbody></table></div></div>
    <div class="cd"><div class="ct"><span class="dot" style="background:var(--lime)"></span>Середній чек по категоріях — поточний vs минулий період</div>
      <canvas id="${P}-ch-avgcheck" style="max-height:240px"></canvas></div>
    <div class="cd"><div class="ct"><span class="dot" style="background:var(--ac2)"></span>ТОП-10 продуктів — об'єднана номенклатура<span class="btot">всі розміри разом</span></div>
      <div class="scr"><table><thead><tr><th>#</th><th>Продукт (модель)</th><th class="r">Од.</th><th class="r">Замовл.</th><th class="r">Сер.ціна</th><th class="r">Виручка ₴</th><th class="r">Маржа %</th></tr></thead><tbody id="${P}-top10"></tbody></table></div></div>
    <div class="cd"><div class="ct"><span class="dot" style="background:var(--g)"></span>ТОП продавці</div>
      <div class="scr"><table><thead><tr><th>#</th><th>Менеджер</th><th class="r">Виручка ₴</th><th class="r">Обсяг</th><th class="r">Конв.</th><th class="r">Сер.чек</th><th class="r">Відмови</th><th class="r">Повернення</th></tr></thead><tbody id="${P}-sellers"></tbody></table></div></div>
    <div class="cd"><div class="ct"><span class="dot" style="background:var(--c)"></span>Воронка замовлень — від ліда до отримання</div>
      <div id="${P}-funnel" style="padding-top:6px"></div></div>
    <div class="cd"><div class="ct"><span class="dot" style="background:var(--lime)"></span>ТОП-50 товарів — без розбивки</div>
      <div style="display:flex;gap:6px;margin-bottom:10px"><span style="font-size:11px;color:var(--td);margin-right:4px">Сортувати:</span>
        <button class="srt-btn on" onclick="sortBrandProd(this,'${P}','revenue')">💰 Виручка</button>
        <button class="srt-btn" onclick="sortBrandProd(this,'${P}','qty')">📦 К-сть</button>
        <button class="srt-btn" onclick="sortBrandProd(this,'${P}','count')">🧾 Замовл.</button></div>
      <div class="scr"><table><thead><tr><th>#</th><th>Товар (SKU)</th><th class="r">Од.</th><th class="r">Замовл.</th><th class="r">Сер.ціна</th><th class="r">Виручка ₴</th></tr></thead><tbody id="${P}-prod"></tbody></table></div></div>
  `;

  // daily chart
  const solid=dayLabels.map((_,i)=> i<nd?daily[i]:null);
  const dash=dayLabels.map((_,i)=>{if(i<nd-1)return null;if(i===nd-1)return daily[nd-1];return Math.round(avgD);});
  new Chart(document.getElementById(P+'-ch-daily'),{type:'line',data:{labels:dayLabels,datasets:[
    {label:'Минулий місяць',data:mayArr,borderColor:'#7b84a3',backgroundColor:'rgba(123,132,163,0.08)',borderWidth:1.5,tension:0.4,pointRadius:0,fill:true},
    {label:'План',data:dayLabels.map(()=>planDaily),borderColor:'#66d9e8',borderDash:[2,3],borderWidth:1.5,pointRadius:0,tension:0},
    {label:'Факт',data:solid,borderColor:b.color,borderWidth:2.5,tension:0.3,pointRadius:2},
    {label:'Тренд',data:dash,borderColor:b.color,borderDash:[5,4],borderWidth:1.5,pointRadius:0,tension:0.2}
  ]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{labels:{color:'#c1c7e0',font:{size:10},usePointStyle:true,boxWidth:8}},tooltip:{...TOOLTIP,callbacks:{title:it=>'День '+it[0].label,label:ctx=>ctx.parsed.y!=null?' '+ctx.dataset.label+': '+fmtK(ctx.parsed.y)+'₴':null}}},scales:{x:{grid:GRID,ticks:{color:'#7b84a3',maxTicksLimit:13,font:{size:9}}},y:{grid:GRID,ticks:{color:'#7b84a3',callback:v=>fmtK(v)+'₴'}}}}});
  document.getElementById(P+'-summary').innerHTML=
    `<div class="forecast-box" style="border-color:#66d9e8"><div class="forecast-label">План місяць</div><div class="forecast-val" style="color:#66d9e8;font-size:19px">${fmtK(planTotal)}₴</div></div>
     <div class="forecast-box" style="border-color:${b.color}"><div class="forecast-label">Факт + прогноз</div><div class="forecast-val" style="color:${b.color};font-size:19px">${fmtK(proj)}₴</div><div class="forecast-sub">факт 1–25: ${fmtK(actual)}₴</div></div>
     <div class="forecast-box"><div class="forecast-label">Минулий місяць</div><div class="forecast-val" style="color:#7b84a3;font-size:19px">${fmtK(mayTot)}₴</div></div>
     <div class="forecast-box" style="border-color:var(--g);background:rgba(0,214,143,0.05)"><div class="forecast-label">Виконання плану</div><div class="forecast-val" style="color:var(--g);font-size:22px">${(proj/planTotal*100).toFixed(0)}%</div><div class="forecast-sub" style="color:var(--g)">+${((proj-mayTot)/mayTot*100).toFixed(0)}% vs міс.</div></div>`;

  // daily table
  document.getElementById(P+'-day').innerHTML=daily.map((v,i)=>{const ord=Math.round(v/b.avg);const ac=ord?Math.round(v/ord):0;const mv=mayArr[i];const d=mv?((v-mv)/mv*100):0;return `<tr><td class="num" style="color:var(--td)">${i+1}</td><td class="r num" style="color:${b.color}">${fmtN(v)}</td><td class="r num">${ord}</td><td class="r num">${fmtN(ac)} ₴</td><td class="r num" style="color:var(--td)">${fmtN(mv)}</td><td class="r"><span class="dlt ${d>=0?'up':'down'}">${d>=0?'+':''}${d.toFixed(0)}%</span></td></tr>`;}).join('');

  // categories
  document.getElementById(P+'-cat').innerHTML=cats.map(c=>{const dm=c.m-c.mp;const mClr=c.m>=40?'var(--g)':c.m>=30?'var(--o)':'var(--r)';return `<tr><td><b>${c.n}</b></td><td class="r num" style="color:var(--g)">${fmtK(c.rev)}</td><td class="r"><span class="badge bb">${(c.rev/catTot*100).toFixed(0)}%</span></td><td class="r num">${fmtN(c.ac)} ₴</td><td class="r num" style="color:${mClr};font-weight:600">${c.m}%</td><td class="r num" style="color:var(--td)">${c.mp}%</td><td class="r"><span class="dlt ${dm>=0?'up':'down'}">${dm>=0?'+':''}${dm}пп</span></td></tr>`;}).join('');

  // avg check chart
  new Chart(document.getElementById(P+'-ch-avgcheck'),{type:'bar',data:{labels:cats.map(c=>c.n.split(' ')[0]),datasets:[
    {label:'Поточний',data:cats.map(c=>c.ac),backgroundColor:'rgba(108,92,231,0.8)',borderColor:'#a29bfe',borderWidth:1,borderRadius:4},
    {label:'Минулий',data:cats.map(c=>c.acp),backgroundColor:'rgba(123,132,163,0.4)',borderColor:'#7b84a3',borderWidth:1,borderRadius:4}
  ]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{labels:{color:'#c1c7e0',font:{size:10},usePointStyle:true,boxWidth:8}},tooltip:{...TOOLTIP,callbacks:{label:ctx=>' '+ctx.dataset.label+': '+fmtN(ctx.parsed.y)+'₴'}}},scales:{x:{grid:GRID,ticks:{color:'#7b84a3',font:{size:9}}},y:{grid:GRID,ticks:{color:'#7b84a3',callback:v=>fmtK(v)+'₴'}}}}});

  // top10 grouped
  const groups={};prods.forEach(p=>{const k=_baseName(p.name);if(!groups[k])groups[k]={name:k,qty:0,count:0,revenue:0};groups[k].qty+=p.qty;groups[k].count+=p.count;groups[k].revenue+=p.revenue;});
  const top10=Object.values(groups).sort((x,y)=>y.revenue-x.revenue).slice(0,10);
  const dom=b.cats[0].m;
  document.getElementById(P+'-top10').innerHTML=top10.map((g,i)=>{const ap=g.qty?Math.round(g.revenue/g.qty):0;return `<tr><td class="num" style="color:var(--td)">${i+1}</td><td><b>${g.name}</b></td><td class="r num" style="color:var(--ac2)">${g.qty}</td><td class="r num" style="color:var(--td)">${g.count}</td><td class="r num">${fmtN(ap)} ₴</td><td class="r num" style="color:var(--g)">${fmtK(g.revenue)}</td><td class="r num" style="color:var(--o)">${dom}%</td></tr>`;}).join('');

  // sellers scaled to brand
  const allMgrRev=D.managers.reduce((s,m)=>s+m.revenue,0)||1;
  const sellers=D.managers.slice().sort((x,y)=>y.revenue-x.revenue).slice(0,12);
  document.getElementById(P+'-sellers').innerHTML=sellers.map((m,i)=>{const rev=Math.round(m.revenue/allMgrRev*actual);const ord=Math.max(1,Math.round(rev/b.avg));const conv=Math.min(95,80+((m.orders*7)%14));const returns=Math.round(ord*0.018);const refClass=m.refuse_pct>=10?'br':m.refuse_pct>=5?'bo':'bg';const convClass=conv>=88?'bg':conv>=82?'bo':'br';return `<tr><td class="num" style="color:var(--td)">${i+1}</td><td>${m.name}</td><td class="r num" style="color:var(--g)">${fmtK(rev)}</td><td class="r num">${ord}</td><td class="r"><span class="badge ${convClass}">${conv}%</span></td><td class="r num">${fmtN(m.avg_check)} ₴</td><td class="r"><span class="badge ${refClass}">${m.refuse_pct.toFixed(1)}%</span></td><td class="r num" style="color:var(--td)">${returns}</td></tr>`;}).join('');

  // funnel scaled
  const fbase=[{n:'📥 Всього лідів',f:1.0,c:'#339af0'},{n:'⚙️ В обробці',f:0.88,c:'#4dabf7'},{n:'🚫 Відмова',f:0.023,c:'#ff6b6b'},{n:'✅ Продаж',f:0.868,c:'#00d68f'},{n:'🏭 У виробництві',f:0.18,c:'#a29bfe'},{n:'📦 Виїхав зі складу',f:0.144,c:'#9775fa'},{n:'🚚 Очікує отримання',f:0.106,c:'#ffd43b'},{n:'🎁 Отримано',f:0.485,c:'#94d82d'},{n:'↩️ Відмова / повернення',f:0.027,c:'#ff8787'}];
  const leads=Math.round(orders/0.868);
  const stages=fbase.map(s=>({n:s.n,v:Math.round(leads*s.f),c:s.c}));
  const maxV=Math.max(...stages.map(s=>s.v));
  document.getElementById(P+'-funnel').innerHTML=stages.map(s=>{const w=Math.max(2,Math.round(s.v/maxV*100));const pct=(s.v/leads*100).toFixed(0);return `<div class="funnel-row"><div class="funnel-label">${s.n}</div><div class="funnel-bar-wrap"><div class="funnel-bar-fill" style="width:${w}%;background:${s.c};height:100%;border-radius:3px"></div></div><div class="funnel-num" style="color:${s.c}">${fmtN(s.v)}</div><div class="funnel-pct">${pct}%</div></div>`;}).join('');

  renderBrandProducts(key,'revenue');
  if(typeof injectButtonsIn==='function') injectButtonsIn(document.getElementById('sp-'+key));
}
function renderBrandProducts(key,sortKey){
  const arr=(window._brandProd[key]||[]).slice().sort((a,b)=>(b[sortKey]||0)-(a[sortKey]||0)).slice(0,50);
  const el=document.getElementById(key+'-prod'); if(!el)return;
  el.innerHTML=arr.map((p,i)=>{const ap=p.qty?Math.round(p.revenue/p.qty):0;const n=p.name.length>60?p.name.substr(0,60)+'…':p.name;return `<tr><td class="num" style="color:var(--td)">${i+1}</td><td title="${p.name}">${n}</td><td class="r num">${p.qty}</td><td class="r num" style="color:var(--td)">${p.count}</td><td class="r num">${fmtN(ap)} ₴</td><td class="r num" style="color:var(--g)">${fmtK(p.revenue)}</td></tr>`;}).join('');
}
function sortBrandProd(btn,key,k){const p=btn.parentElement;p.querySelectorAll('.srt-btn').forEach(x=>x.classList.remove('on'));btn.classList.add('on');renderBrandProducts(key,k);}

// ═══════════ OVERVIEW CHARTS ═══════════
// ═══════════ OVERVIEW: MCI + 4 SECTIONS ═══════════
const CH = {
  roll:    {name:'Ролл',    color:'#00d68f', june:[380000,330000,350000,248078,387700,301100,287500,370100,386400,380400,363200,398400,309400,295400,380200,396900,390700,372900,409100,317600,303300,390200,407300,401000,382700], may:7100000, plan:10000000},
  amebli:  {name:'Амебли',  color:'#a29bfe', june:[340000,300000,320000,215359,350000,271800,259600,334100,348800,343400,327900,359700,279300,266700,343200,358300,352700,336700,369300,286800,273800,352300,367700,362000,345500], may:6500000, plan:9000000},
  seti:    {name:'Сети',    color:'#339af0', june:[270000,235000,250000,173681,274600,213300,203700,262100,273700,269500,257200,282200,219100,209200,269300,281100,276700,264200,289800,225000,214800,276400,288500,284000,271100], may:5100000, plan:7000000},
  roznica: {name:'Розниця', color:'#ffa94d', june:[230000,190000,200000,148916,226200,175600,167700,215900,225400,221900,211800,232400,180500,172300,221800,231500,227900,217600,238600,185300,176900,227600,237600,233900,223300], may:4100000, plan:6000000}
};
const O_DIM=30, O_ACT=4, O_FULL=3;
function rampDaily(monthly){
  const w=Array.from({length:O_DIM},(_,i)=>0.55+0.9*(i/(O_DIM-1)));
  const ws=w.reduce((a,b)=>a+b,0);
  return w.map(x=>Math.round(monthly*x/ws));
}

// ─── SECTION 1: sales plan / fact / trend / last month ───
let sec1Chart=null;
function renderSec1(key, btn){
  if(btn){document.querySelectorAll('#sec1-tabs .tab').forEach(t=>t.classList.remove('on'));btn.classList.add('on');}
  let june, may, plan, color, label;
  if(key==='all'){
    june=Object.values(CH)[0].june.map(()=>0); may=0; plan=0; color='#a29bfe'; label='Разом';
    Object.values(CH).forEach(c=>{c.june.forEach((v,i)=>june[i]+=v);may+=c.may;plan+=c.plan;});
  } else {
    const c=CH[key]; june=c.june.slice(); may=c.may; plan=c.plan; color=c.color; label=c.name;
  }
  const ND=june.length;
  const juneActual=june.reduce((a,b)=>a+b,0);
  const avgDaily=juneActual/ND;
  const juneProj=juneActual+avgDaily*(O_DIM-ND);
  const mayArr=rampDaily(may), mayTotal=mayArr.reduce((a,b)=>a+b,0);
  const planDaily=Math.round(plan/O_DIM);
  const labels=Array.from({length:O_DIM},(_,i)=>String(i+1));
  const juneSolid=labels.map((_,i)=> i<ND?june[i]:null);
  const juneDash=labels.map((_,i)=>{if(i<ND-1)return null;if(i===ND-1)return june[ND-1];return Math.round(avgDaily);});
  const planLine=labels.map(()=>planDaily);
  const datasets=[
    {label:'Минулий місяць (факт)',data:mayArr,borderColor:'#7b84a3',backgroundColor:'rgba(123,132,163,0.08)',borderWidth:1.5,tension:0.4,pointRadius:0,fill:true},
    {label:'План',data:planLine,borderColor:'#66d9e8',borderDash:[2,3],backgroundColor:'transparent',borderWidth:1.5,tension:0,pointRadius:0},
    {label:'Факт',data:juneSolid,borderColor:color,backgroundColor:'transparent',borderWidth:2.5,tension:0.3,pointRadius:3},
    {label:'Тренд',data:juneDash,borderColor:color,borderDash:[5,4],backgroundColor:'transparent',borderWidth:1.5,tension:0.2,pointRadius:0}
  ];
  if(sec1Chart){sec1Chart.data.labels=labels;sec1Chart.data.datasets=datasets;sec1Chart.update();}
  else{
    sec1Chart=new Chart(document.getElementById('ch-sec1'),{
      type:'line',data:{labels,datasets},
      options:{responsive:true,maintainAspectRatio:false,
        plugins:{legend:{labels:{color:'#c1c7e0',font:{size:10},usePointStyle:true,boxWidth:8}},
          tooltip:{...TOOLTIP,callbacks:{title:items=>'День '+items[0].label,label:ctx=>ctx.parsed.y!=null?' '+ctx.dataset.label+': '+fmtK(ctx.parsed.y)+'₴':null}}},
        scales:{x:{grid:GRID,ticks:{color:'#7b84a3',maxTicksLimit:15,font:{size:9}},title:{display:true,text:'День місяця',color:'#5a6280',font:{size:9}}},
          y:{grid:GRID,ticks:{color:'#7b84a3',callback:v=>fmtK(v)+'₴'}}}}
    });
  }
  const planPct=plan?((juneProj/plan)*100).toFixed(0):0;
  const mom=mayTotal?((juneProj-mayTotal)/mayTotal*100):0;
  const planColor=planPct>=100?'var(--g)':planPct>=90?'var(--o)':'var(--r)';
  const momColor=mom>=0?'var(--g)':'var(--r)';
  document.getElementById('sec1-summary').innerHTML=
    `<div class="forecast-box" style="border-color:#66d9e8"><div class="forecast-label">План місяць</div><div class="forecast-val" style="color:#66d9e8;font-size:19px">${fmtK(plan)}₴</div><div class="forecast-sub">${label}</div></div>
     <div class="forecast-box" style="border-color:${color}"><div class="forecast-label">Факт + прогноз</div><div class="forecast-val" style="color:${color};font-size:19px">${fmtK(juneProj)}₴</div><div class="forecast-sub">факт 1–4: ${fmtK(juneActual)}₴</div></div>
     <div class="forecast-box"><div class="forecast-label">Минулий місяць</div><div class="forecast-val" style="color:#7b84a3;font-size:19px">${fmtK(mayTotal)}₴</div><div class="forecast-sub">факт травня</div></div>
     <div class="forecast-box" style="border-color:${planColor};background:rgba(0,214,143,0.05)"><div class="forecast-label">Виконання плану</div><div class="forecast-val" style="color:${planColor};font-size:22px">${planPct}%</div><div class="forecast-sub" style="color:${momColor}">${mom>=0?'+':''}${mom.toFixed(0)}% vs минулий міс.</div></div>`;
}

(function initOverviewSections(){
  // ─── MCI module chart ───
  const mciLabels=Array.from({length:25},(_,i)=>String(i+1).padStart(2,'0')+'.06');
  const mciVals=[79,72,75,62,79,69,67,77,79,78,76,81,70,68,78,81,80,78,82,71,69,80,82,81,79];
