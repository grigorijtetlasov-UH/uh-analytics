      plugins:{legend:{display:false},tooltip:{...TOOLTIP,callbacks:{label:ctx=>ctx.dataset.yAxisID==='y2'?' MCI: '+ctx.parsed.y+'%':' Продажі: '+ctx.parsed.y+'K₴'}}},
      scales:{
        x:{grid:{display:false},ticks:{color:'#5a6280',font:{size:8},maxTicksLimit:7}},
        y:{display:false,grid:{display:false}},
        y2:{display:false,grid:{display:false},min:50,max:90}
      }}
  });

  // ─── SECTION 2: marketing — ДРР по днях ───
