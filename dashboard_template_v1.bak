<!DOCTYPE html>
<html lang="uk">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0">
<title>UH — Analytics Dashboard</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<style>
@import url('https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap');
:root{
  --bg:#0c0f1a;--s:#151929;--s2:#1c2137;--s3:#242b47;
  --brd:#2a3050;--brd2:#3a4170;
  --t:#e4e8f7;--t2:#c1c7e0;--td:#7b84a3;--td2:#5a6280;
  --ac:#6c5ce7;--ac2:#a29bfe;
  --g:#00d68f;--gd:rgba(0,214,143,.15);
  --o:#ffa94d;--od:rgba(255,169,77,.15);
  --r:#ff6b6b;--rd:rgba(255,107,107,.15);
  --b:#339af0;--bd:rgba(51,154,240,.15);
  --y:#ffd43b;--p:#da77f2;--c:#66d9e8;--lime:#94d82d;
}
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--t);min-height:100vh;padding:14px 18px;font-size:12px;line-height:1.4}

/* ── HEADER ── */
.hdr{text-align:center;margin-bottom:16px;position:relative}
.hdr h1{font-size:24px;font-weight:700;background:linear-gradient(135deg,var(--ac2),var(--g));-webkit-background-clip:text;-webkit-text-fill-color:transparent;letter-spacing:-.5px}
.hdr .sub{color:var(--td);font-size:11px;letter-spacing:2px;text-transform:uppercase;margin-top:3px}
.hdr .stamp{display:inline-block;font-family:'JetBrains Mono',monospace;font-size:9px;color:var(--td2);margin-top:4px;padding:2px 10px;background:var(--s);border:1px solid var(--brd);border-radius:10px}

/* ── TOP NAV TABS ── */
.main-tabs{display:flex;gap:3px;margin-bottom:16px;background:var(--s);border-radius:11px;padding:4px;border:1px solid var(--brd);flex-wrap:wrap}
.mtab{flex:1;min-width:130px;padding:10px 8px;border-radius:8px;text-align:center;cursor:pointer;font-size:12px;font-weight:600;color:var(--td);border:none;background:none;transition:.15s;letter-spacing:.3px}
.mtab:hover{color:var(--t);background:var(--s2)}
.mtab.on{background:linear-gradient(135deg,var(--ac),var(--ac2));color:#fff;box-shadow:0 2px 10px rgba(108,92,231,.3)}
.mpnl{display:none}.mpnl.on{display:block;animation:fade .2s ease}
@keyframes fade{from{opacity:0;transform:translateY(4px)}to{opacity:1;transform:none}}

/* ── INNER TABS (sub-tabs) ── */
.tabs{display:flex;gap:2px;margin-bottom:12px;background:var(--s2);border-radius:9px;padding:3px;border:1px solid var(--brd);flex-wrap:wrap}
.tab{flex:1;min-width:100px;padding:7px 6px;border-radius:7px;text-align:center;cursor:pointer;font-size:11px;font-weight:500;color:var(--td);border:none;background:none;transition:.15s}
.tab:hover{color:var(--t);background:var(--s3)}
.tab.on{background:var(--ac);color:#fff}
.pnl{display:none}.pnl.on{display:block;animation:fade .2s ease}

/* ── KPI CARDS ── */
.kpi-row{display:grid;grid-template-columns:repeat(auto-fit,minmax(155px,1fr));gap:9px;margin-bottom:14px}
.kpi{background:var(--s);border:1px solid var(--brd);border-radius:11px;padding:12px 11px;position:relative;overflow:hidden}
.kpi::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;border-radius:11px 11px 0 0}
.kpi.c1::before{background:linear-gradient(90deg,var(--ac),var(--ac2))}
.kpi.c2::before{background:var(--g)}
.kpi.c3::before{background:var(--o)}
.kpi.c4::before{background:var(--b)}
.kpi.c5::before{background:var(--p)}
.kpi.c6::before{background:var(--c)}
.kpi.c7::before{background:var(--r)}
.kpi.c8::before{background:var(--lime)}
.kpi.c9::before{background:var(--y)}
.kl{font-size:9px;text-transform:uppercase;letter-spacing:1px;color:var(--td);margin-bottom:3px;font-weight:500}
.kv{font-family:'JetBrains Mono',monospace;font-size:19px;font-weight:600;line-height:1.1}
.ku{font-size:9px;color:var(--td);margin-left:2px;font-family:'DM Sans'}
.ks{font-size:9px;color:var(--td);margin-top:3px;display:flex;align-items:center;gap:5px;flex-wrap:wrap}
.dlt{display:inline-block;font-family:'JetBrains Mono',monospace;font-size:9px;font-weight:600;padding:1px 5px;border-radius:4px}
.dlt.up{background:var(--gd);color:var(--g)}
.dlt.down{background:var(--rd);color:var(--r)}
.dlt.warn{background:var(--od);color:var(--o)}
.dlt.neu{background:rgba(123,132,163,.15);color:var(--td)}

/* ── KPI SALES BLOCKS ── */
.kpi-sales-wrap{margin-bottom:14px;padding:14px;background:var(--s);border:1px solid var(--brd);border-radius:13px}
.kpi-sales-head{display:flex;align-items:center;gap:8px;margin-bottom:11px}
.kpi-sales-head .ttl{font-size:12px;font-weight:600;color:var(--t)}
.kpi-sales-head .sub{font-size:10px;color:var(--td)}
.kpi-sales-row{display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:10px}
.kpi-sales{background:var(--bg);border:1px solid var(--brd);border-radius:10px;padding:11px 12px;position:relative;overflow:hidden}
.kpi-sales::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;border-radius:10px 10px 0 0}
.kpi-sales.good::before{background:linear-gradient(90deg,var(--g),#34d399)}
.kpi-sales.warn::before{background:linear-gradient(90deg,var(--o),#fbbf24)}
.kpi-sales.bad::before{background:linear-gradient(90deg,var(--r),#f87171)}
.kpi-sales-label{font-size:9px;text-transform:uppercase;letter-spacing:1px;color:var(--td);margin-bottom:5px;font-weight:500}
.kpi-sales-vals{display:flex;align-items:baseline;gap:10px;margin-bottom:4px}
.kpi-sales-period{display:flex;flex-direction:column}
.kpi-sales-tag{font-size:8px;color:var(--td);letter-spacing:.5px;text-transform:uppercase;margin-bottom:1px}
.kpi-sales-num{font-family:'JetBrains Mono',monospace;font-size:17px;font-weight:600;line-height:1}
.kpi-sales-num.good{color:var(--g)}
.kpi-sales-num.warn{color:var(--o)}
.kpi-sales-num.bad{color:var(--r)}
.kpi-sales-pct{font-size:10px;color:var(--td);margin-left:1px}
.kpi-sales-tg{font-size:9px;color:var(--td);margin-top:4px;padding-top:5px;border-top:1px solid var(--brd)}
.kpi-sales-tg b{color:var(--t);font-weight:600}

/* ── INSIGHT ALERTS ── */
.ins-wrap{display:flex;flex-direction:column;gap:6px;margin-bottom:14px}
.ins{background:var(--s);border:1px solid var(--brd);border-radius:9px;padding:9px 13px;display:flex;align-items:flex-start;gap:10px;font-size:11px;line-height:1.4}
.ins-ico{font-size:15px;flex-shrink:0;margin-top:1px}
.ins-txt{color:var(--t2)}
.ins-txt b{color:var(--t)}
.ins-good{border-left:3px solid var(--g)}
.ins-warn{border-left:3px solid var(--o)}
.ins-bad{border-left:3px solid var(--r)}
.ins-info{border-left:3px solid var(--b)}

/* ── CARDS / GRID ── */
.cd{background:var(--s);border:1px solid var(--brd);border-radius:11px;padding:14px;margin-bottom:11px}
.ct{font-size:12px;font-weight:600;margin-bottom:8px;display:flex;align-items:center;gap:7px}
.ct .dot{width:7px;height:7px;border-radius:50%;background:var(--ac);flex-shrink:0}
.ct .btot{font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--td);margin-left:auto;padding:2px 8px;background:var(--s2);border-radius:5px}
.cd-d{font-size:10px;color:var(--td);margin-bottom:10px;line-height:1.4}
.g2{display:grid;grid-template-columns:1fr 1fr;gap:11px;margin-bottom:11px}
.g3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:11px;margin-bottom:11px}
.g4{display:grid;grid-template-columns:repeat(4,1fr);gap:11px;margin-bottom:11px}
@media(max-width:900px){.g2,.g3,.g4{grid-template-columns:1fr}}
canvas{max-height:280px}

/* ── TABLES ── */
table{width:100%;border-collapse:collapse;font-size:11px}
th{background:var(--s2);padding:7px 9px;text-align:left;font-weight:600;color:var(--td);font-size:9px;text-transform:uppercase;letter-spacing:.5px;white-space:nowrap;border-bottom:1px solid var(--brd)}
th.r,td.r{text-align:right}
td{padding:6px 9px;border-bottom:1px solid rgba(255,255,255,.04);color:var(--t2)}
tbody tr:hover td{background:rgba(108,92,231,.06)}
.scr{max-height:420px;overflow-y:auto}
.scr::-webkit-scrollbar{width:5px}
.scr::-webkit-scrollbar-thumb{background:var(--brd2);border-radius:3px}
.scr::-webkit-scrollbar-track{background:var(--s2)}

/* ── BADGES ── */
.badge{display:inline-block;padding:2px 7px;border-radius:5px;font-size:9px;font-weight:600;letter-spacing:.2px}
.bg{background:var(--gd);color:var(--g)}.bo{background:var(--od);color:var(--o)}
.br{background:var(--rd);color:var(--r)}.bb{background:var(--bd);color:var(--b)}
.bn{background:rgba(123,132,163,.15);color:var(--td)}
.num{font-family:'JetBrains Mono',monospace;font-size:11px;font-weight:500}

/* ── BAR LIST ── */
.bar-row{display:flex;align-items:center;gap:9px;padding:5px 4px;border-bottom:1px solid rgba(255,255,255,.03)}
.bar-row:last-child{border-bottom:none}
.bar-name{font-size:11px;flex:1;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:200px;color:var(--t2)}
.bar-wrap{flex:2;background:var(--s2);border-radius:3px;height:6px;min-width:50px}
.bar-fill{height:100%;border-radius:3px;transition:width 1s cubic-bezier(.4,0,.2,1)}
.bar-val{font-family:'JetBrains Mono',monospace;font-size:10px;font-weight:600;min-width:60px;text-align:right;color:var(--t2)}

/* ── SORT BUTTONS ── */
.srt-btn{padding:5px 10px;border-radius:6px;border:1px solid var(--brd);background:var(--s);color:var(--td);font-size:11px;cursor:pointer;transition:.15s}
.srt-btn:hover{background:var(--s2);color:var(--t)}
.srt-btn.on{background:var(--ac);color:#fff;border-color:var(--ac)}

/* ── FINANCE INPUTS ── */
.fin-input-row{display:flex;align-items:center;justify-content:space-between;padding:7px 0;border-bottom:1px solid rgba(255,255,255,.05)}
.fin-input-row:last-child{border-bottom:none}
.fin-input-label{font-size:12px;color:var(--t2);flex:1}
.fin-input{background:var(--s2);border:1px solid var(--brd2);border-radius:6px;color:var(--t);font-family:'JetBrains Mono',monospace;font-size:12px;padding:5px 9px;width:120px;text-align:right}
.fin-input:focus{outline:none;border-color:var(--ac)}
.fin-row{display:flex;justify-content:space-between;padding:6px 0;border-bottom:1px solid rgba(255,255,255,.04);font-size:12px}
.fin-row:last-child{border-bottom:none}
.fin-row .lbl{color:var(--td)}
.fin-row .val{font-family:'JetBrains Mono',monospace;font-weight:500}
.fin-row.total{padding-top:10px;margin-top:4px;border-top:1px solid var(--brd);border-bottom:none}
.fin-row.total .lbl{color:var(--t);font-weight:600;font-size:13px}
.fin-row.total .val{font-size:14px;font-weight:700}

/* ── TREND MINI CARDS ── */
.mm-card{background:linear-gradient(180deg,rgba(108,92,231,.06),rgba(108,92,231,.02));border:1px solid var(--brd);border-radius:10px;padding:12px 14px}
.mm-h{font-size:13px;font-weight:700;color:var(--ac2);margin-bottom:8px;padding-bottom:6px;border-bottom:1px solid var(--brd)}
.mm-rows{display:flex;flex-direction:column;gap:5px}
.mm-r{display:flex;justify-content:space-between;gap:8px;font-size:11px}
.mm-l{color:var(--td)}
.mm-v{color:var(--t);text-align:right}
.mm-trend{margin-top:8px;padding:4px 8px;border-radius:6px;font-size:11px;font-weight:600;text-align:center}
.mm-trend.up{background:var(--gd);color:var(--g)}
.mm-trend.down{background:var(--rd);color:var(--r)}
.mm-trend.warn{background:var(--od);color:var(--o)}
.mm-trend.neu{background:rgba(123,132,163,.12);color:var(--td)}

/* ── PROGRESS ── */
.progress-wrap{margin-top:6px}
.progress-track{height:5px;background:var(--s2);border-radius:3px;overflow:hidden;margin-bottom:3px}
.progress-fill{height:100%;border-radius:3px;transition:width 1.2s cubic-bezier(.4,0,.2,1)}
.progress-labels{display:flex;justify-content:space-between;font-size:9px;color:var(--td)}

/* ── FUNNEL ── */
.funnel-row{display:flex;align-items:center;gap:10px;padding:8px 0;border-bottom:1px solid rgba(255,255,255,.04)}
.funnel-row:last-child{border-bottom:none}
.funnel-label{font-size:11px;color:var(--t2);flex:1}
.funnel-bar-wrap{flex:3;background:var(--s2);border-radius:3px;height:8px}
.funnel-bar-fill{height:100%;border-radius:3px}
.funnel-num{font-family:'JetBrains Mono',monospace;font-size:11px;font-weight:600;min-width:80px;text-align:right}
.funnel-pct{font-size:9px;color:var(--td);min-width:45px;text-align:right}

/* ── FORECAST WIDGET ── */
.forecast-box{background:var(--s2);border:1px solid var(--brd2);border-radius:10px;padding:14px;text-align:center}
.forecast-label{font-size:9px;text-transform:uppercase;letter-spacing:1px;color:var(--td);margin-bottom:6px}
.forecast-val{font-family:'JetBrains Mono',monospace;font-size:24px;font-weight:700;color:var(--g)}
.forecast-sub{font-size:10px;color:var(--td);margin-top:4px}

/* ── DRR GAUGE ── */
.drr-row{display:flex;align-items:center;gap:10px;padding:7px 0;border-bottom:1px solid rgba(255,255,255,.04)}
.drr-row:last-child{border-bottom:none}
.drr-brand{font-size:11px;color:var(--t2);min-width:120px}
.drr-bar-wrap{flex:1;background:var(--s2);border-radius:3px;height:8px;overflow:hidden}
.drr-bar-fill{height:100%;border-radius:3px;transition:width 1.2s}
.drr-val{font-family:'JetBrains Mono',monospace;font-size:12px;font-weight:700;min-width:55px;text-align:right}
.drr-target{font-size:9px;color:var(--td);min-width:50px;text-align:right}

/* ── SECTIONS / AI / MCI ── */
.sec{margin-bottom:18px}
.sec-head{display:flex;align-items:center;gap:10px;margin-bottom:10px;padding-bottom:8px;border-bottom:1px solid var(--brd)}
.sec-num{width:26px;height:26px;border-radius:8px;background:linear-gradient(135deg,var(--ac),var(--ac2));display:flex;align-items:center;justify-content:center;font-weight:700;font-size:13px;color:#fff;flex-shrink:0}
.sec-title{font-size:15px;font-weight:700;color:var(--t)}
.sec-sub{font-size:10px;color:var(--td);margin-left:auto;text-align:right}
.ai-block{background:linear-gradient(180deg,rgba(108,92,231,.06),transparent);border:1px solid var(--brd);border-radius:10px;padding:12px 14px;margin-top:12px}
.ai-head{display:flex;align-items:center;gap:7px;font-size:11px;font-weight:700;color:var(--ac2);margin-bottom:9px;letter-spacing:.3px}
.ai-cols{display:grid;grid-template-columns:1fr 1fr;gap:14px}
@media(max-width:800px){.ai-cols{grid-template-columns:1fr}}
.ai-col-h{font-size:10px;text-transform:uppercase;letter-spacing:.5px;margin-bottom:5px;font-weight:600}
.ai-col-h.win{color:var(--g)}.ai-col-h.prob{color:var(--r)}
.ai-item{font-size:11px;color:var(--t2);line-height:1.45;padding:4px 0 4px 15px;position:relative}
.ai-item::before{content:'';position:absolute;left:2px;top:10px;width:5px;height:5px;border-radius:50%}
.ai-item.win::before{background:var(--g)}.ai-item.prob::before{background:var(--r)}
.ai-item b{color:var(--t)}
.mci-bar{display:flex;align-items:center;gap:16px;background:linear-gradient(135deg,rgba(0,214,143,.07),rgba(108,92,231,.05));border:1px solid var(--brd);border-radius:12px;padding:12px 16px;margin-bottom:18px}
.mci-gauge{flex-shrink:0;text-align:center;min-width:96px}
.mci-pct{font-family:'JetBrains Mono',monospace;font-size:30px;font-weight:700;line-height:1}
.mci-glabel{font-size:9px;text-transform:uppercase;letter-spacing:1px;color:var(--td);margin-top:3px}
.mci-status{font-size:10px;font-weight:700;padding:2px 10px;border-radius:10px;margin-top:6px;display:inline-block}
.mci-desc{flex:1;font-size:11px;color:var(--t2);line-height:1.45;min-width:180px}
.mci-desc b{color:var(--t)}
.mci-chart-wrap{flex:1.3;min-width:200px;height:88px;position:relative}
@media(max-width:820px){.mci-bar{flex-wrap:wrap}.mci-chart-wrap{flex-basis:100%;width:100%}}
/* ── FEEDBACK BUTTON + MODAL ── */
.cd,.mci-bar,.sec{position:relative}
.fb-btn{display:inline-flex;align-items:center;gap:5px;background:var(--s2);border:1px solid var(--brd);color:var(--td);font-family:'DM Sans',sans-serif;font-size:10px;font-weight:500;padding:4px 9px;border-radius:7px;cursor:pointer;transition:.15s;opacity:.5;white-space:nowrap}
.fb-btn:hover{opacity:1;color:var(--ac2);border-color:var(--ac);background:var(--s3)}
.fb-btn i{font-style:normal;font-size:11px}
.fb-overlay{position:fixed;inset:0;background:rgba(6,8,15,.72);display:none;align-items:center;justify-content:center;z-index:1000;padding:20px}
.fb-overlay.on{display:flex}
.fb-modal{background:var(--s);border:1px solid var(--brd2);border-radius:14px;padding:22px;width:100%;max-width:440px;box-shadow:0 24px 70px rgba(0,0,0,.55)}
.fb-modal h3{font-size:16px;font-weight:700;color:var(--t);margin-bottom:4px}
.fb-mod-name{font-size:11px;color:var(--ac2);margin-bottom:13px;font-family:'JetBrains Mono',monospace}
.fb-modal p{font-size:12px;color:var(--td);margin-bottom:12px;line-height:1.45}
.fb-modal textarea{width:100%;min-height:110px;background:var(--bg);border:1px solid var(--brd);border-radius:9px;color:var(--t);font-family:'DM Sans',sans-serif;font-size:13px;padding:11px;resize:vertical;box-sizing:border-box}
.fb-modal textarea:focus{outline:none;border-color:var(--ac)}
.fb-actions{display:flex;gap:10px;margin-top:14px;justify-content:flex-end}
.fb-cancel{background:var(--s2);border:1px solid var(--brd);color:var(--td);padding:9px 16px;border-radius:8px;font-size:12px;font-weight:500;cursor:pointer;font-family:'DM Sans',sans-serif}
.fb-cancel:hover{color:var(--t)}
.fb-send{background:linear-gradient(135deg,var(--ac),var(--ac2));border:none;color:#fff;padding:9px 18px;border-radius:8px;font-size:12px;font-weight:600;cursor:pointer;font-family:'DM Sans',sans-serif}
.fb-send:hover{opacity:.9}
.fb-ok{display:none;text-align:center;padding:18px 0}
.fb-ok .ico{font-size:38px}
.fb-ok p{color:var(--g);font-size:13px;font-weight:600;margin-top:8px}
/* ── PERIOD / DATE CONTROLS ── */
.period-bar{display:flex;align-items:center;gap:8px;flex-wrap:wrap;background:var(--s);border:1px solid var(--brd);border-radius:10px;padding:8px 14px;margin-bottom:14px}
.pb-label{font-size:11px;color:var(--td);font-weight:500}
.pb-select{background:var(--s2);border:1px solid var(--brd2);color:var(--t);font-family:'DM Sans',sans-serif;font-size:12px;padding:5px 9px;border-radius:7px;cursor:pointer}
.pb-select:focus{outline:none;border-color:var(--ac)}
.pb-select.full{width:100%;margin-top:4px}
.pb-hint{font-size:10px;color:var(--td2);margin-left:auto;font-family:'JetBrains Mono',monospace}
.dt-field-label{display:block;font-size:10px;text-transform:uppercase;letter-spacing:.5px;color:var(--td);margin-top:10px;margin-bottom:2px;font-weight:600}
.dt-btn .dt-lbl{font-size:10px}
.ftr{text-align:center;color:var(--td2);font-size:10px;padding-top:18px;border-top:1px solid var(--brd);margin-top:24px;font-family:'JetBrains Mono',monospace}
</style>
</head>
<body>

<div class="hdr">
  <h1>United Home · Analytics Dashboard</h1>
  <div class="sub">United Home Group · Червень 2026</div>
  <div class="stamp">Поточний: 2026-06 · Дані за 1–4 числа · Оновлено 04.06.2026 · Версія 2.0</div>
</div>

<!-- ═══════════════════ MAIN TABS ═══════════════════ -->
<!-- Global period selector -->
<div class="period-bar">
  <span class="pb-label">📅 Період:</span>
  <select class="pb-select" id="globalPeriod" onchange="toggleGlobalCustom();applyGlobalPeriod()">
    <option value="current">Червень 2026 (поточний)</option>
    <option value="2026-05">Травень 2026</option>
    <option value="2026-04">Квітень 2026</option>
    <option value="2026-03">Березень 2026</option>
    <option value="last7">Останні 7 днів</option>
    <option value="last30">Останні 30 днів</option>
    <option value="custom">Довільний діапазон (точні дати)</option>
  </select>
  <span id="gpCustom" style="display:none;align-items:center;gap:6px">
    <input type="date" class="pb-select" id="gpFrom" onchange="applyGlobalPeriod()">
    <span class="pb-label">–</span>
    <input type="date" class="pb-select" id="gpTo" onchange="applyGlobalPeriod()">
  </span>
  <span class="pb-label">Порівняти з:</span>
  <select class="pb-select" id="globalCompare" onchange="toggleGlobalCustom();applyGlobalPeriod()">
    <option value="prev">Попередній місяць (травень)</option>
    <option value="yoy">Той самий період торік</option>
    <option value="2026-04">Квітень 2026</option>
    <option value="custom">Довільний діапазон (точні дати)</option>
    <option value="none">Без порівняння</option>
  </select>
  <span id="gcCustom" style="display:none;align-items:center;gap:6px">
    <input type="date" class="pb-select" id="gcFrom" onchange="applyGlobalPeriod()">
    <span class="pb-label">–</span>
    <input type="date" class="pb-select" id="gcTo" onchange="applyGlobalPeriod()">
  </span>
  <span class="pb-hint" id="pbHint">Поточний місяць vs попередній</span>
</div>

<div class="main-tabs">
  <button class="mtab on"  onclick="swMain('overview',this)">📊 Огляд</button>
  <button class="mtab"     onclick="swMain('sales',this)">💰 Продажі</button>
  <button class="mtab"     onclick="swMain('marketing',this)">📣 Маркетинг</button>
  <button class="mtab"     onclick="swMain('finance',this)">📈 Фінанси P&L</button>
</div>

<!-- ══════════════════════════════════════════════════
     TAB 1 — ОГЛЯД
══════════════════════════════════════════════════ -->
<div class="mpnl on" id="mp-overview">

  <!-- MCI mini-module -->
  <div class="mci-bar">
    <div class="mci-gauge">
      <div class="mci-pct" id="mci-value" style="color:var(--g)">78%</div>
      <div class="mci-glabel">MCI індекс</div>
      <div class="mci-status" id="mci-status" style="background:var(--gd);color:var(--g)">Сприятливий</div>
    </div>
    <div class="mci-desc">
      <b>Market Conditions Index</b> — композитний індекс ринкових умов (макро + сезон + воєнні фактори). Сьогодні <b>78%</b> — сприятливий період для меблевого ринку. Кореляція з продажами <b>+0.82</b>.
    </div>
    <div class="mci-chart-wrap"><canvas id="ch-mci"></canvas></div>
  </div>

  <!-- ═══ SECTION 1 — SALES ═══ -->
  <div class="sec">
    <div class="sec-head"><div class="sec-num">1</div><div class="sec-title">💰 Продажі — план / факт / тренд</div><div class="sec-sub">по кожному джерелу<br>vs факт минулого місяця</div></div>
    <div class="cd">
      <div class="tabs" id="sec1-tabs" style="margin-bottom:10px">
        <button class="tab on" onclick="renderSec1('all',this)">🌐 Разом</button>
        <button class="tab" onclick="renderSec1('roll',this)">🟢 Ролл</button>
        <button class="tab" onclick="renderSec1('amebli',this)">🟣 Амебли</button>
        <button class="tab" onclick="renderSec1('seti',this)">🔵 Сети</button>
        <button class="tab" onclick="renderSec1('roznica',this)">🟠 Розниця</button>
      </div>
      <canvas id="ch-sec1" style="max-height:300px"></canvas>
      <div id="sec1-summary" style="display:grid;grid-template-columns:repeat(auto-fit,minmax(135px,1fr));gap:10px;margin-top:12px"></div>
      <div class="ai-block">
        <div class="ai-head">🤖 AI-висновки · продажі</div>
        <div class="ai-cols">
          <div>
            <div class="ai-col-h win">✓ Досягнення</div>
            <div class="ai-item win">Прогноз червня <b>~33.6M₴</b> — на <b>+47%</b> вище факту травня (22.8M₴). Старт місяця на рівні пікових днів травня.</div>
            <div class="ai-item win">Ролл і Амебли перевиконують план: <b>~105%</b> і <b>~106%</b> при поточному темпі.</div>
            <div class="ai-item win">Sofino (у «Сети») — найкраще зростання, чек 5 728₴ вищий за Ролл.</div>
          </div>
          <div>
            <div class="ai-col-h prob">⚠ Проблеми</div>
            <div class="ai-item prob">Середній чек <b>−25%</b> (5 513₴ vs 7 371₴) — зсув у дешевші SKU, тисне на маржу.</div>
            <div class="ai-item prob">Розниця: ST Даринок і ДрімТаун дають <b>0₴ при 15 замовленнях</b> — дані не підтягуються.</div>
            <div class="ai-item prob">Прогноз на 3 днях — висока невизначеність, для стабільного тренду треба ≥7 днів.</div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- ═══ SECTION 2 — MARKETING ═══ -->
  <div class="sec">
    <div class="sec-head"><div class="sec-num">2</div><div class="sec-title">📣 Маркетинг — ДРР, трафік, конверсії</div><div class="sec-sub">тренд + приріст<br>vs травень</div></div>
    <div class="cd">
      <div class="kpi-row" style="margin-bottom:12px">
        <div class="kpi c7"><div class="kl">ДРР Amebli</div><div class="kv" style="color:var(--r)">51.5<span class="ku">%</span></div><div class="ks">vs 12% · <span class="dlt down">+39пп</span></div></div>
        <div class="kpi c3"><div class="kl">ДРР Matrasroll</div><div class="kv" style="color:var(--o)">24.2<span class="ku">%</span></div><div class="ks">vs 5% · <span class="dlt down">+19пп</span></div></div>
        <div class="kpi c2"><div class="kl">ДРР загальний</div><div class="kv" style="color:var(--lime)">10.1<span class="ku">%</span></div><div class="ks">vs 2.3% · <span class="dlt down">+7.8пп</span></div></div>
        <div class="kpi c4"><div class="kl">Трафік/день</div><div class="kv">~8.6K</div><div class="ks">vs 7.1K · <span class="dlt up">+21%</span></div></div>
        <div class="kpi c5"><div class="kl">Конв. трафік→лід</div><div class="kv">3.7<span class="ku">%</span></div><div class="ks">vs 3.2% · <span class="dlt up">+0.5пп</span></div></div>
        <div class="kpi c8"><div class="kl">Конв. лід→замовл.</div><div class="kv">87<span class="ku">%</span></div><div class="ks">vs 84% · <span class="dlt up">+3пп</span></div></div>
      </div>
      <canvas id="ch-sec2" style="max-height:240px"></canvas>
      <div class="ai-block">
        <div class="ai-head">🤖 AI-висновки · маркетинг</div>
        <div class="ai-cols">
          <div>
            <div class="ai-col-h win">✓ Досягнення</div>
            <div class="ai-item win">Трафік <b>+21%</b> до травня, конверсія лід→замовлення <b>87%</b> (вище цілі 85%).</div>
            <div class="ai-item win">ДРР замовлень <b>4.18%</b> — у межах цілі ≤7%. Загальна юніт-економіка тримається.</div>
            <div class="ai-item win">Конверсія трафік→лід зросла до 3.7% — лендінги працюють ефективніше.</div>
          </div>
          <div>
            <div class="ai-col-h prob">⚠ Проблеми</div>
            <div class="ai-item prob"><b>ДРР Amebli 51.5%</b> — критично. Реклама з'їдає половину виручки. Терміновий аудит кампаній.</div>
            <div class="ai-item prob"><b>ДРР Matrasroll 24.2%</b> — вище норми ≤15%. Перерозподілити бюджет у кращі кампанії.</div>
            <div class="ai-item prob">Загальний ДРР відгрузки виріс +7.8пп — масштабування реклами випереджає відгрузки.</div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- ═══ SECTION 3 — RETURNS / REFUSALS ═══ -->
  <div class="sec">
    <div class="sec-head"><div class="sec-num">3</div><div class="sec-title">↩️ Повернення / Відмови</div><div class="sec-sub">коротко<br>по кожному пункту</div></div>
    <div class="cd">
      <div class="kpi-row" style="margin-bottom:12px">
        <div class="kpi c2"><div class="kl">Відмови всього</div><div class="kv" style="color:var(--g)">2.6<span class="ku">%</span></div><div class="ks">15 з 573 · було 50% <span class="dlt up">−47пп</span></div></div>
        <div class="kpi c2"><div class="kl">Відмови Matrasroll</div><div class="kv">2.6<span class="ku">%</span></div><div class="ks">13 замовлень</div></div>
        <div class="kpi c2"><div class="kl">Відмови Amebli</div><div class="kv">2.2<span class="ku">%</span></div><div class="ks">5 замовлень</div></div>
        <div class="kpi c3"><div class="kl">Повернення</div><div class="kv">~1.8<span class="ku">%</span></div><div class="ks">оцінка по відгрузках</div></div>
        <div class="kpi c7"><div class="kl">Спам / дублі</div><div class="kv">236</div><div class="ks">221 спам + 15 дублів</div></div>
        <div class="kpi c4"><div class="kl">Недодзвон</div><div class="kv">51</div><div class="ks">потребує обробки</div></div>
      </div>
      <canvas id="ch-sec3" style="max-height:200px"></canvas>
      <div class="ai-block">
        <div class="ai-head">🤖 AI-висновки · повернення / відмови</div>
        <div class="ai-cols">
          <div>
            <div class="ai-col-h win">✓ Досягнення</div>
            <div class="ai-item win">Відмови <b>2.6%</b> проти 50% торік — колл-центр працює відмінно. Один з найкращих показників.</div>
            <div class="ai-item win">Amebli тримає <b>2.2%</b> відмов — найнижчий рівень серед брендів.</div>
            <div class="ai-item win">Повернення ~1.8% — у нормі для меблів/матраців.</div>
          </div>
          <div>
            <div class="ai-col-h prob">⚠ Проблеми</div>
            <div class="ai-item prob"><b>221 спам-заявка</b> на узгодженні — забивають воронку. Потрібен фільтр на вході.</div>
            <div class="ai-item prob"><b>51 недодзвон</b> — втрачені ліди. Налаштувати авто-повторні дзвінки.</div>
            <div class="ai-item prob">Ростислав Куций: відмови 6.2% — вище цілі ≤5%, потрібен контроль якості.</div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- ═══ SECTION 4 — SHIPMENTS ═══ -->
  <div class="sec">
    <div class="sec-head"><div class="sec-num">4</div><div class="sec-title">📦 Відгрузки — по днях</div><div class="sec-sub">факт / тренд / план<br>vs травень</div></div>
    <div class="cd">
      <canvas id="ch-sec4" style="max-height:280px"></canvas>
      <div id="sec4-summary" style="display:grid;grid-template-columns:repeat(auto-fit,minmax(135px,1fr));gap:10px;margin-top:12px"></div>
      <div class="ai-block">
        <div class="ai-head">🤖 AI-висновки · відгрузки</div>
        <div class="ai-cols">
          <div>
            <div class="ai-col-h win">✓ Досягнення</div>
            <div class="ai-item win">День 2 червня: <b>496K₴</b> відгрузок — здоровий темп після старту місяця.</div>
            <div class="ai-item win">Травень: 16.96M₴ відгрузок, стабільний ритм виробництва і складу.</div>
            <div class="ai-item win">Конверсія замовлення→відгрузка зростає — менше «зависань» на складі.</div>
          </div>
          <div>
            <div class="ai-col-h prob">⚠ Проблеми</div>
            <div class="ai-item prob">Прогноз відгрузок <b>~14M₴</b> — нижче плану 17M₴ і травня. Відгрузки відстають від замовлень.</div>
            <div class="ai-item prob">Розрив замовлення↔відгрузки росте — ризик накопичення необроблених замовлень.</div>
            <div class="ai-item prob">Старт місяця (день 1: 167K₴) повільний — перевірити графік виробництва.</div>
          </div>
        </div>
      </div>
    </div>
  </div>

</div><!-- /mp-overview -->


<!-- ══════════════════════════════════════════════════
     TAB 2 — ПРОДАЖІ
══════════════════════════════════════════════════ -->
<div class="mpnl" id="mp-sales">

  <!-- Sub-tabs by brand -->
  <div class="tabs">
    <button class="tab on" onclick="swSales('all',this)">🌐 Всі</button>
    <button class="tab" onclick="swSales('matrasroll',this)">🟢 Matrasroll</button>
    <button class="tab" onclick="swSales('amebli',this)">🟡 Amebli</button>
    <button class="tab" onclick="swSales('sofino',this)">🔵 Sofino</button>
    <button class="tab" onclick="swSales('showrooms',this)">🏪 Шоу-руми</button>
  </div>

  <!-- All brands KPI -->
  <div id="sp-all" class="pnl on">
    <div class="kpi-row">
      <div class="kpi c1"><div class="kl">Обсяг продажів (1–25)</div><div class="kv">28.6M<span class="ku">₴</span></div><div class="ks">факт червня · <span class="dlt up">+47% vs міс.</span></div></div>
      <div class="kpi c2"><div class="kl">Замовлень</div><div class="kv">~5 190</div><div class="ks">~208 зам/день</div></div>
      <div class="kpi c3"><div class="kl">Середній чек</div><div class="kv">5 513<span class="ku">₴</span></div><div class="ks"><span class="dlt down">−25.2%</span> vs 7 371₴</div></div>
      <div class="kpi c4"><div class="kl">Маржинальність</div><div class="kv">~44<span class="ku">%</span></div><div class="ks"><span class="dlt down">−2пп</span> vs 46%</div></div>
      <div class="kpi c5"><div class="kl">Прогноз місяць</div><div class="kv" style="color:var(--g)">~34.3M<span class="ku">₴</span></div><div class="ks">при поточному темпі</div></div>
      <div class="kpi c6"><div class="kl">Конверсія лід→зам</div><div class="kv">~87<span class="ku">%</span></div><div class="ks">ціль ≥85%</div></div>
    </div>

    <!-- Sales daily chart: plan / fact / trend / last month -->
    <div class="cd">
      <div class="ct"><span class="dot"></span>Продажі по днях — план / факт / тренд<span class="btot">vs минулий місяць</span></div>
      <div class="cd-d">Суцільна — факт червня (1–25). Пунктир — тренд до кінця місяця. Сіра область — факт травня. Бірюзовий пунктир — план.</div>
      <canvas id="ch-sales-daily" style="max-height:280px"></canvas>
      <div id="sales-daily-summary" style="display:grid;grid-template-columns:repeat(auto-fit,minmax(135px,1fr));gap:10px;margin-top:12px"></div>
    </div>

    <!-- Sales daily table -->
    <div class="cd">
      <div class="ct"><span class="dot" style="background:var(--b)"></span>Таблиця продажів по днях<span class="btot">1–25 червня</span></div>
      <div class="scr" style="max-height:340px">
        <table>
          <thead><tr><th>День</th><th class="r">Факт ₴</th><th class="r">Замовл.</th><th class="r">Сер.чек</th><th class="r">Минулий міс. ₴</th><th class="r">Δ%</th></tr></thead>
          <tbody id="sales-day-tbody"></tbody>
        </table>
      </div>
    </div>

    <!-- Categories with margin -->
    <div class="cd">
      <div class="ct"><span class="dot" style="background:var(--p)"></span>Продажі по категоріях — маржа vs минулий місяць</div>
      <div class="scr">
        <table>
          <thead><tr><th>Категорія</th><th class="r">Виручка ₴</th><th class="r">Частка</th><th class="r">Сер.чек</th><th class="r">Маржа %</th><th class="r">Маржа мин.міс</th><th class="r">Δ маржі</th></tr></thead>
          <tbody id="cat-tbody"></tbody>
        </table>
      </div>
    </div>

    <!-- Avg check by category -->
    <div class="cd">
      <div class="ct"><span class="dot" style="background:var(--lime)"></span>Середній чек по категоріях — поточний vs минулий період</div>
      <canvas id="ch-cat-avgcheck" style="max-height:240px"></canvas>
    </div>

    <!-- Top 10 grouped products -->
    <div class="cd">
      <div class="ct"><span class="dot" style="background:var(--ac2)"></span>ТОП-10 продуктів — об'єднана номенклатура<span class="btot">всі розміри/тканини разом</span></div>
      <div class="cd-d">Номенклатура згрупована: всі розміри та варіанти однієї моделі рахуються разом (напр. «ORANGE Handy» = всі розміри).</div>
      <div class="scr">
        <table>
          <thead><tr><th>#</th><th>Продукт (модель)</th><th class="r">Од.</th><th class="r">Замовл.</th><th class="r">Сер.ціна</th><th class="r">Виручка ₴</th><th class="r">Маржа %</th></tr></thead>
          <tbody id="top10-tbody"></tbody>
        </table>
      </div>
    </div>

    <!-- Top sellers -->
    <div class="cd">
      <div class="ct"><span class="dot" style="background:var(--g)"></span>ТОП продавці<span class="btot">23 активних</span></div>
      <div class="cd-d">Виручка · обсяг · конверсія · середній чек · відмови · повернення</div>
      <div class="scr">
        <table>
          <thead><tr><th>#</th><th>Менеджер</th><th class="r">Виручка ₴</th><th class="r">Обсяг (зам.)</th><th class="r">Конв.</th><th class="r">Сер.чек</th><th class="r">Відмови</th><th class="r">Повернення</th></tr></thead>
          <tbody id="sellers-tbody"></tbody>
        </table>
      </div>
    </div>

    <!-- Funnel -->
    <div class="cd">
      <div class="ct"><span class="dot" style="background:var(--c)"></span>Воронка замовлень — від ліда до отримання</div>
      <div class="cd-d">Повний шлях замовлення по статусах CRM/1С.</div>
      <div id="funnel-container" style="padding-top:6px"></div>
    </div>

    <!-- Top 50 raw products -->
    <div class="cd">
      <div class="ct"><span class="dot" style="background:var(--lime)"></span>ТОП-50 товарів — без розбивки за характеристиками<span class="btot" id="prod-sort-label">По виручці</span></div>
      <div style="display:flex;gap:6px;margin-bottom:10px">
        <span style="font-size:11px;color:var(--td);margin-right:4px">Сортувати:</span>
        <button class="srt-btn on" onclick="sortProd(this,'revenue')">💰 Виручка</button>
        <button class="srt-btn" onclick="sortProd(this,'qty')">📦 К-сть</button>
        <button class="srt-btn" onclick="sortProd(this,'count')">🧾 Замовл.</button>
      </div>
      <div class="scr">
        <table>
          <thead><tr><th>#</th><th>Товар (SKU)</th><th class="r">Од.</th><th class="r">Замовл.</th><th class="r">Сер.ціна</th><th class="r">Виручка ₴</th></tr></thead>
          <tbody id="products-tbody"></tbody>
        </table>
      </div>
    </div>
  </div><!-- /sp-all -->

  <div id="sp-matrasroll" class="pnl"></div>
  <div id="sp-amebli" class="pnl"></div>
  <div id="sp-sofino" class="pnl"></div>
  <div id="sp-showrooms" class="pnl"></div>

</div><!-- /mp-sales -->


<!-- ══════════════════════════════════════════════════
     TAB 3 — МАРКЕТИНГ
══════════════════════════════════════════════════ -->
<div class="mpnl" id="mp-marketing">

  <!-- DRR KPI row -->
  <div class="kpi-row">
