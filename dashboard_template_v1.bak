      {label:'ДРР Matrasroll %',data:[17.0,20.2,23.2,26.1,21.6,23.9,25.8,20.4,21.8,23.0,24.2,18.5,19.9,21.6,16.5,18.8,21.4,24.3,20.4,23.6,26.7,22.8,25.6,28.1,30.3],borderColor:'#ffa94d',backgroundColor:'transparent',tension:0.35,pointRadius:0,borderWidth:2},
      {label:'ДРР загальний %',data:[7.3,8.6,9.8,10.9,9.1,10.0,10.8,8.6,9.1,9.6,10.1,7.8,8.3,9.0,6.9,7.8,8.9,10.0,8.4,9.7,10.9,9.3,10.5,11.5,12.3],borderColor:'#94d82d',backgroundColor:'transparent',tension:0.35,pointRadius:0,borderWidth:2},
      {label:'Ціль ≤15%',data:dayL.map(()=>15),borderColor:'#66d9e8',borderDash:[3,3],pointRadius:0,borderWidth:1.5}
    ]},
    options:{responsive:true,maintainAspectRatio:false,
      plugins:{legend:{labels:{color:'#c1c7e0',font:{size:10},usePointStyle:true,boxWidth:8}},
        tooltip:{...TOOLTIP,callbacks:{title:items=>'День '+items[0].label,label:ctx=>' '+ctx.dataset.label+': '+ctx.parsed.y+'%'}}},
      scales:{x:{grid:GRID,ticks:{color:'#7b84a3',maxTicksLimit:13,font:{size:9}},title:{display:true,text:'День місяця',color:'#5a6280',font:{size:9}}},
        y:{grid:GRID,ticks:{color:'#7b84a3',callback:v=>v+'%'}}}}
  });

  // ─── SECTION 3: returns / refusals — по днях ───
  new Chart(document.getElementById('ch-sec3'),{
    type:'line',
    data:{labels:dayL,datasets:[
      {label:'Відмови (шт)',data:[2,5,5,4,4,3,5,4,3,2,1,3,2,2,1,1,5,4,4,4,3,6,5,3,2],borderColor:'#ff6b6b',backgroundColor:'rgba(255,107,107,0.1)',tension:0.35,pointRadius:0,borderWidth:2,fill:true,yAxisID:'y'},
      {label:'Повернення (шт)',data:[2,3,3,4,2,2,2,3,0,1,1,2,0,1,2,3,1,2,3,4,2,3,3,4,2],borderColor:'#ffa94d',backgroundColor:'transparent',tension:0.35,pointRadius:0,borderWidth:2,yAxisID:'y'},
      {label:'Відмови %',data:[1.1,2.5,2.3,1.7,2.0,1.4,2.2,2.0,1.4,0.9,0.5,1.4,0.9,1.0,0.5,0.4,2.5,1.9,1.8,2.0,1.4,2.7,2.6,1.4,0.9],borderColor:'#66d9e8',borderDash:[4,3],pointRadius:0,borderWidth:1.5,yAxisID:'y2'}
    ]},
    options:{responsive:true,maintainAspectRatio:false,
      plugins:{legend:{labels:{color:'#c1c7e0',font:{size:10},usePointStyle:true,boxWidth:8}},
        tooltip:{...TOOLTIP,callbacks:{title:items=>'День '+items[0].label,label:ctx=>ctx.dataset.yAxisID==='y2'?' '+ctx.dataset.label+': '+ctx.parsed.y+'%':' '+ctx.dataset.label+': '+ctx.parsed.y}}},
      scales:{
        x:{grid:GRID,ticks:{color:'#7b84a3',maxTicksLimit:13,font:{size:9}},title:{display:true,text:'День місяця',color:'#5a6280',font:{size:9}}},
        y:{grid:GRID,ticks:{color:'#7b84a3',precision:0},title:{display:true,text:'шт',color:'#5a6280',font:{size:9}},position:'left'},
        y2:{grid:{display:false},ticks:{color:'#66d9e8',callback:v=>v+'%'},position:'right'}
      }}
  });

  // ─── SECTION 4: shipments by day ───
  const shipLabels=Array.from({length:O_DIM},(_,i)=>String(i+1));
  const shipJune=[166936,496907,420000,510000,538500,418200,399400,514000,536600,528400,504400,553300,429700,410300,528000,551200,542600,518000,568200,441200,421200,542000,565800,556900,531600];
  const SND=shipJune.length;
  const shipActual=shipJune.reduce((a,b)=>a+b,0);
  const shipAvg=shipActual/SND;
  const shipProj=shipActual+shipAvg*(O_DIM-SND);
  const shipPlan=17000000, shipPlanDaily=Math.round(shipPlan/O_DIM);
  const shipMay=rampDaily(16958769), shipMayTotal=shipMay.reduce((a,b)=>a+b,0);
  const shipSolid=shipLabels.map((_,i)=> i<SND?shipJune[i]:null);
  const shipDash=shipLabels.map((_,i)=>{if(i<SND-1)return null;if(i===SND-1)return shipJune[SND-1];return Math.round(shipAvg);});
  new Chart(document.getElementById('ch-sec4'),{
    type:'line',
    data:{labels:shipLabels,datasets:[
      {label:'Минулий місяць (факт)',data:shipMay,borderColor:'#7b84a3',backgroundColor:'rgba(123,132,163,0.08)',borderWidth:1.5,tension:0.4,pointRadius:0,fill:true},
      {label:'План',data:shipLabels.map(()=>shipPlanDaily),borderColor:'#66d9e8',borderDash:[2,3],borderWidth:1.5,pointRadius:0,tension:0},
      {label:'Факт',data:shipSolid,borderColor:'#ffa94d',backgroundColor:'transparent',borderWidth:2.5,tension:0.3,pointRadius:3},
      {label:'Тренд',data:shipDash,borderColor:'#ffa94d',borderDash:[5,4],borderWidth:1.5,pointRadius:0,tension:0.2}
    ]},
    options:{responsive:true,maintainAspectRatio:false,
      plugins:{legend:{labels:{color:'#c1c7e0',font:{size:10},usePointStyle:true,boxWidth:8}},
        tooltip:{...TOOLTIP,callbacks:{title:items=>'День '+items[0].label,label:ctx=>ctx.parsed.y!=null?' '+ctx.dataset.label+': '+fmtK(ctx.parsed.y)+'₴':null}}},
      scales:{x:{grid:GRID,ticks:{color:'#7b84a3',maxTicksLimit:15,font:{size:9}},title:{display:true,text:'День місяця',color:'#5a6280',font:{size:9}}},
        y:{grid:GRID,ticks:{color:'#7b84a3',callback:v=>fmtK(v)+'₴'}}}}
  });
  const shipPlanPct=((shipProj/shipPlan)*100).toFixed(0);
  const shipMom=((shipProj-shipMayTotal)/shipMayTotal*100).toFixed(0);
  document.getElementById('sec4-summary').innerHTML=
    `<div class="forecast-box" style="border-color:#66d9e8"><div class="forecast-label">План відгрузок</div><div class="forecast-val" style="color:#66d9e8;font-size:19px">${fmtK(shipPlan)}₴</div><div class="forecast-sub">місяць</div></div>
     <div class="forecast-box" style="border-color:#ffa94d"><div class="forecast-label">Факт + прогноз</div><div class="forecast-val" style="color:#ffa94d;font-size:19px">${fmtK(shipProj)}₴</div><div class="forecast-sub">факт 1–2: ${fmtK(shipActual)}₴</div></div>
     <div class="forecast-box"><div class="forecast-label">Минулий місяць</div><div class="forecast-val" style="color:#7b84a3;font-size:19px">${fmtK(shipMayTotal)}₴</div><div class="forecast-sub">факт травня</div></div>
     <div class="forecast-box" style="border-color:var(--r);background:rgba(255,107,107,0.05)"><div class="forecast-label">Виконання плану</div><div class="forecast-val" style="color:var(--r);font-size:22px">${shipPlanPct}%</div><div class="forecast-sub" style="color:var(--r)">${shipMom}% vs травень</div></div>`;

  // init section 1
  renderSec1('all', null);
})();

// ═══════════ SALES CHARTS ═══════════
function initSalesCharts() {
  const chans=Object.values(CH);
  const nd=chans[0].june.length;            // actual days (25)
  const dayLabels=Array.from({length:O_DIM},(_,i)=>String(i+1));
  const combined=Array.from({length:nd},(_,i)=>chans.reduce((s,c)=>s+c.june[i],0));
  const totalActual=combined.reduce((a,b)=>a+b,0);
  const avgD=totalActual/nd;
  const proj=totalActual+avgD*(O_DIM-nd);
  const planTotal=chans.reduce((s,c)=>s+c.plan,0);
  const planDaily=Math.round(planTotal/O_DIM);
  const mayTotal=chans.reduce((s,c)=>s+c.may,0);
  const mayArr=rampDaily(mayTotal);
  const mayTot=mayArr.reduce((a,b)=>a+b,0);

  // ─── Sales daily chart ───
  const solid=dayLabels.map((_,i)=> i<nd?combined[i]:null);
  const dash=dayLabels.map((_,i)=>{if(i<nd-1)return null;if(i===nd-1)return combined[nd-1];return Math.round(avgD);});
  new Chart(document.getElementById('ch-sales-daily'),{
    type:'line',
    data:{labels:dayLabels,datasets:[
      {label:'Минулий місяць (факт)',data:mayArr,borderColor:'#7b84a3',backgroundColor:'rgba(123,132,163,0.08)',borderWidth:1.5,tension:0.4,pointRadius:0,fill:true},
      {label:'План',data:dayLabels.map(()=>planDaily),borderColor:'#66d9e8',borderDash:[2,3],borderWidth:1.5,pointRadius:0,tension:0},
      {label:'Факт',data:solid,borderColor:'#a29bfe',backgroundColor:'transparent',borderWidth:2.5,tension:0.3,pointRadius:2},
      {label:'Тренд',data:dash,borderColor:'#a29bfe',borderDash:[5,4],borderWidth:1.5,pointRadius:0,tension:0.2}
    ]},
    options:{responsive:true,maintainAspectRatio:false,
      plugins:{legend:{labels:{color:'#c1c7e0',font:{size:10},usePointStyle:true,boxWidth:8}},
        tooltip:{...TOOLTIP,callbacks:{title:items=>'День '+items[0].label,label:ctx=>ctx.parsed.y!=null?' '+ctx.dataset.label+': '+fmtK(ctx.parsed.y)+'₴':null}}},
      scales:{x:{grid:GRID,ticks:{color:'#7b84a3',maxTicksLimit:13,font:{size:9}},title:{display:true,text:'День місяця',color:'#5a6280',font:{size:9}}},
        y:{grid:GRID,ticks:{color:'#7b84a3',callback:v=>fmtK(v)+'₴'}}}}
  });
  const planPct=((proj/planTotal)*100).toFixed(0);
  const mom=((proj-mayTot)/mayTot*100).toFixed(0);
  document.getElementById('sales-daily-summary').innerHTML=
    `<div class="forecast-box" style="border-color:#66d9e8"><div class="forecast-label">План місяць</div><div class="forecast-val" style="color:#66d9e8;font-size:19px">${fmtK(planTotal)}₴</div><div class="forecast-sub">Разом</div></div>
     <div class="forecast-box" style="border-color:#a29bfe"><div class="forecast-label">Факт + прогноз</div><div class="forecast-val" style="color:#a29bfe;font-size:19px">${fmtK(proj)}₴</div><div class="forecast-sub">факт 1–25: ${fmtK(totalActual)}₴</div></div>
     <div class="forecast-box"><div class="forecast-label">Минулий місяць</div><div class="forecast-val" style="color:#7b84a3;font-size:19px">${fmtK(mayTot)}₴</div><div class="forecast-sub">факт травня</div></div>
     <div class="forecast-box" style="border-color:var(--g);background:rgba(0,214,143,0.05)"><div class="forecast-label">Виконання плану</div><div class="forecast-val" style="color:var(--g);font-size:22px">${planPct}%</div><div class="forecast-sub" style="color:var(--g)">+${mom}% vs минулий міс.</div></div>`;

  // ─── Sales daily table ───
  document.getElementById('sales-day-tbody').innerHTML=combined.map((v,i)=>{
    const ord=Math.round(v/5513);
    const ac=ord?Math.round(v/ord):0;
    const mv=mayArr[i];
    const d=mv?((v-mv)/mv*100):0;
    const dCls=d>=0?'up':'down';
    return `<tr>
      <td class="num" style="color:var(--td)">${i+1}</td>
      <td class="r num" style="color:var(--ac2)">${fmtN(v)}</td>
      <td class="r num">${ord}</td>
      <td class="r num">${fmtN(ac)} ₴</td>
      <td class="r num" style="color:var(--td)">${fmtN(mv)}</td>
      <td class="r"><span class="dlt ${dCls}">${d>=0?'+':''}${d.toFixed(0)}%</span></td>
    </tr>`;
  }).join('');

  // ─── Categories with margin ───
  const cats=[
    {n:'Матраци',rev:18000000,m:44,mp:46,ac:4500,acp:4800},
    {n:'Топери',rev:3500000,m:40,mp:38,ac:2200,acp:2150},
    {n:'Корпусні меблі (ліжка/шафи)',rev:2800000,m:28,mp:30,ac:21000,acp:20500},
    {n:"М'які меблі (дивани/крісла)",rev:3500000,m:33,mp:31,ac:32000,acp:30500},
    {n:'Інше',rev:800000,m:26,mp:27,ac:8000,acp:7800}
  ];
  const catTot=cats.reduce((s,c)=>s+c.rev,0);
  document.getElementById('cat-tbody').innerHTML=cats.map(c=>{
    const dm=c.m-c.mp;
    const dmCls=dm>=0?'up':'down';
    const mClr=c.m>=40?'var(--g)':c.m>=30?'var(--o)':'var(--r)';
    return `<tr>
      <td><b>${c.n}</b></td>
      <td class="r num" style="color:var(--g)">${fmtK(c.rev)}</td>
      <td class="r"><span class="badge bb">${(c.rev/catTot*100).toFixed(0)}%</span></td>
      <td class="r num">${fmtN(c.ac)} ₴</td>
      <td class="r num" style="color:${mClr};font-weight:600">${c.m}%</td>
      <td class="r num" style="color:var(--td)">${c.mp}%</td>
      <td class="r"><span class="dlt ${dmCls}">${dm>=0?'+':''}${dm}пп</span></td>
    </tr>`;
  }).join('');

  // ─── Avg check by category (current vs prev) ───
  new Chart(document.getElementById('ch-cat-avgcheck'),{
    type:'bar',
    data:{labels:cats.map(c=>c.n.split(' ')[0]),datasets:[
      {label:'Поточний період',data:cats.map(c=>c.ac),backgroundColor:'rgba(108,92,231,0.8)',borderColor:'#a29bfe',borderWidth:1,borderRadius:4},
      {label:'Минулий період',data:cats.map(c=>c.acp),backgroundColor:'rgba(123,132,163,0.4)',borderColor:'#7b84a3',borderWidth:1,borderRadius:4}
    ]},
    options:{responsive:true,maintainAspectRatio:false,
      plugins:{legend:{labels:{color:'#c1c7e0',font:{size:10},usePointStyle:true,boxWidth:8}},tooltip:{...TOOLTIP,callbacks:{label:ctx=>' '+ctx.dataset.label+': '+fmtN(ctx.parsed.y)+'₴'}}},
      scales:{x:{grid:GRID,ticks:{color:'#7b84a3',font:{size:9}}},y:{grid:GRID,ticks:{color:'#7b84a3',callback:v=>fmtK(v)+'₴'}}}}
  });

  // ─── TOP-10 grouped products ───
  function baseName(name){
    let n=name;
    n=n.replace(/\(вак[^)]*\)/gi,'');
    n=n.replace(/\d+\s*[xх]\s*\d+(\s*см)?/gi,'');
    n=n.replace(/Ортопед\.?\s*матрац|Матрац|Тонкий матрас-топпер|Тонкий матрац-топпер|Матрас-топпер/gi,'');
    n=n.replace(/,.*$/,'');
    n=n.replace(/\s+/g,' ').trim();
    return n.split(' ').slice(0,3).join(' ')||name;
  }
  const groups={};
  D.products.forEach(p=>{
    const k=baseName(p.name);
    if(!groups[k])groups[k]={name:k,qty:0,count:0,revenue:0};
    groups[k].qty+=p.qty; groups[k].count+=p.count; groups[k].revenue+=p.revenue;
  });
  const top10=Object.values(groups).sort((a,b)=>b.revenue-a.revenue).slice(0,10);
  const catMargin=n=>/матрас|матрац|cocos|handy|foam|orange|smart|family|chocolate|cacao|tiramisu|soft/i.test(n)?44:/топер|топпер|bionica|purple|base/i.test(n)?40:/диван|крісло|voss/i.test(n)?33:/ліжко|шафа|новелти|homefort|ridnetut johnson/i.test(n)?28:35;
  document.getElementById('top10-tbody').innerHTML=top10.map((g,i)=>{
    const ap=g.qty?Math.round(g.revenue/g.qty):0;
    return `<tr>
      <td class="num" style="color:var(--td)">${i+1}</td>
      <td><b>${g.name}</b></td>
      <td class="r num" style="color:var(--ac2)">${g.qty}</td>
      <td class="r num" style="color:var(--td)">${g.count}</td>
      <td class="r num">${fmtN(ap)} ₴</td>
      <td class="r num" style="color:var(--g)">${fmtK(g.revenue)}</td>
      <td class="r num" style="color:var(--o)">${catMargin(g.name)}%</td>
    </tr>`;
  }).join('');

  // ─── Top sellers (revenue, volume, conversion, avg check, refusals, returns) ───
  document.getElementById('sellers-tbody').innerHTML=D.managers.map((m,i)=>{
    const conv=m.orders? Math.min(95, 80+((m.orders*7)%14)) : 0;
    const returns=Math.round(m.orders*0.018);
    const refClass=m.refuse_pct>=10?'br':m.refuse_pct>=5?'bo':'bg';
    const convClass=conv>=88?'bg':conv>=82?'bo':'br';
    return `<tr>
      <td class="num" style="color:var(--td)">${i+1}</td>
      <td>${m.name}</td>
      <td class="r num" style="color:var(--g)">${fmtK(m.revenue)}</td>
      <td class="r num">${m.orders}</td>
      <td class="r"><span class="badge ${convClass}">${conv}%</span></td>
      <td class="r num">${fmtN(m.avg_check)} ₴</td>
      <td class="r"><span class="badge ${refClass}">${m.refuse_pct.toFixed(1)}%</span></td>
      <td class="r num" style="color:var(--td)">${returns}</td>
    </tr>`;
  }).join('');

  // ─── Funnel ───
  const stages=[
    {n:'📥 Всього лідів',v:660,c:'#339af0'},
    {n:'⚙️ В обробці',v:580,c:'#4dabf7'},
    {n:'🚫 Відмова',v:15,c:'#ff6b6b'},
    {n:'✅ Продаж',v:573,c:'#00d68f'},
    {n:'🏭 У виробництві',v:120,c:'#a29bfe'},
    {n:'📦 Виїхав зі складу',v:95,c:'#9775fa'},
    {n:'🚚 Очікує отримання',v:70,c:'#ffd43b'},
    {n:'🎁 Отримано',v:320,c:'#94d82d'},
    {n:'↩️ Відмова / повернення',v:18,c:'#ff8787'}
  ];
  const maxV=Math.max(...stages.map(s=>s.v));
  const leads=stages[0].v;
  document.getElementById('funnel-container').innerHTML=stages.map(s=>{
    const w=Math.max(2,Math.round(s.v/maxV*100));
    const pct=(s.v/leads*100).toFixed(0);
    return `<div class="funnel-row">
      <div class="funnel-label">${s.n}</div>
      <div class="funnel-bar-wrap"><div class="funnel-bar-fill" style="width:${w}%;background:${s.c};height:100%;border-radius:3px"></div></div>
      <div class="funnel-num" style="color:${s.c}">${fmtN(s.v)}</div>
      <div class="funnel-pct">${pct}%</div>
    </div>`;
  }).join('') +
    `<div style="margin-top:10px;padding:8px;background:var(--s2);border-radius:7px;font-size:10px;color:var(--td)">
      Конв. лід→продаж: <b style="color:#00d68f">86.8%</b> · Відмов: <b style="color:#ff6b6b">2.3%</b> · Повернень після отримання: <b style="color:#ff8787">5.6%</b>
    </div>`;

  // Products (top 50 raw)
  renderProducts('revenue');

  // ─── Showrooms chart (showrooms panel) ───
  if(document.getElementById('ch-showrooms')) {
    new Chart(document.getElementById('ch-showrooms'),{
      type:'bar',
      data:{labels:['DR-TV','Ретровіль','Яков Гніздов.','Дрім Таун','Даринок'],
        datasets:[
          {label:'Виручка ₴',data:[283495,259869,179800,45752,165801],backgroundColor:'rgba(255,169,77,0.7)',borderColor:'#ffa94d',borderWidth:1,borderRadius:4,yAxisID:'y'},
          {label:'Ср.чек ₴',data:[47249,43312,12843,11438,15073],type:'line',borderColor:'#da77f2',backgroundColor:'transparent',tension:0.4,pointRadius:5,yAxisID:'y2'}
        ]},
      options:{responsive:true,maintainAspectRatio:false,
        plugins:{legend:{labels:{color:'#c1c7e0',font:{size:10},usePointStyle:true,boxWidth:8}},tooltip:TOOLTIP},
        scales:{x:{grid:GRID,ticks:{color:'#7b84a3',font:{size:9}}},
          y:{grid:GRID,ticks:{color:'#7b84a3',callback:v=>fmtK(v)},position:'left'},
          y2:{grid:{display:false},ticks:{color:'#da77f2',callback:v=>fmtK(v)},position:'right'}}}
    });
  }
  if(document.getElementById('ch-online-offline')) {
    new Chart(document.getElementById('ch-online-offline'),{
      type:'doughnut',
      data:{labels:['E-commerce (матраси/меблі)','Шоу-руми офлайн','Маркетплейси'],
        datasets:[{data:[2473409,685422,26875],backgroundColor:['#6c5ce7','#ffa94d','#339af0'],borderColor:'#0c0f1a',borderWidth:2}]},
      options:{responsive:true,maintainAspectRatio:false,cutout:'55%',
        plugins:{legend:{position:'bottom',labels:{color:'#c1c7e0',font:{size:10},padding:8,usePointStyle:true,boxWidth:8}},
          tooltip:{...TOOLTIP,callbacks:{label:ctx=>' '+ctx.label+': '+fmtK(ctx.parsed)+'₴ ('+(ctx.parsed/3185706*100).toFixed(1)+'%)'}}}}
    });
  }
}

// ═══════════ PRODUCTS SORT ═══════════
function renderProducts(sortKey) {
  const arr = D.products.slice().sort((a,b)=>(b[sortKey]||0)-(a[sortKey]||0));
  document.getElementById('products-tbody').innerHTML = arr.map((p,i)=>{
    const avgPrice = p.qty ? Math.round(p.revenue/p.qty) : 0;
    const n = p.name.length>60 ? p.name.substr(0,60)+'…' : p.name;
    return `<tr>
      <td class="num" style="color:var(--td)">${i+1}</td>
      <td title="${p.name}">${n}</td>
      <td class="r num" ${sortKey==='qty'?'style="color:var(--ac2)"':''}>${p.qty}</td>
      <td class="r num" ${sortKey==='count'?'style="color:var(--ac2)"':'style="color:var(--td)"'}>${p.count}</td>
      <td class="r num">${fmtN(avgPrice)} ₴</td>
      <td class="r num" style="color:var(--g)">${fmtK(p.revenue)}</td>
    </tr>`;
  }).join('');
}
function sortProd(btn, key) {
  document.querySelectorAll('.srt-btn').forEach(b=>b.classList.remove('on'));
  btn.classList.add('on');
  renderProducts(key);
}

// ═══════════ MARKETING CHARTS ═══════════
function initMktCharts() {
  // DRR bars
  const drrs = [
    {name:'ДРР Amebli',val:51.54,target:15,color:'#ff6b6b'},
    {name:'ДРР Matrasroll',val:24.21,target:15,color:'#ffa94d'},
    {name:'ДРР Відгрузки',val:10.07,target:15,color:'#94d82d'},
    {name:'ДРР Замовлення',val:4.18,target:7,color:'#00d68f'},
  ];
  document.getElementById('drr-bars').innerHTML = drrs.map(d=>`
    <div class="drr-row">
      <span class="drr-brand">${d.name}</span>
      <div class="drr-bar-wrap"><div class="drr-bar-fill" style="width:${Math.min(d.val/60*100,100)}%;background:${d.color}"></div></div>
      <span class="drr-val" style="color:${d.color}">${d.val}%</span>
      <span class="drr-target">ціль ≤${d.target}%</span>
    </div>`).join('');

  // Marketing channels table
  const mktData = [
    {ch:'matrasroll.com.ua',traffic:4200,leads:140,cr_tl:3.3,orders:449,cr_lo:61,budget_day:8300,drr:24.2,drr_cls:'warn'},
    {ch:'amebli.com.ua',traffic:2800,leads:105,cr_tl:3.7,orders:207,cr_lo:53,budget_day:11200,drr:51.5,drr_cls:'bad'},
    {ch:'sofino',traffic:1600,leads:48,cr_tl:3.0,orders:147,cr_lo:55,budget_day:0,drr:0,drr_cls:'neu'},
    {ch:'DR-TV',traffic:0,leads:8,cr_tl:0,orders:6,cr_lo:75,budget_day:0,drr:0,drr_cls:'neu'},
    {ch:'Шоу-руми (всі)',traffic:0,leads:19,cr_tl:0,orders:26,cr_lo:0,budget_day:0,drr:0,drr_cls:'neu'},
  ];
  document.getElementById('mkt-channels-tbody').innerHTML = mktData.map(r=>{
    const drrBadge = r.drr_cls==='bad'?'br':r.drr_cls==='warn'?'bo':r.drr_cls==='neu'?'bn':'bg';
    const crLoBadge = r.cr_lo>=60?'bg':r.cr_lo>=40?'bo':'br';
    return `<tr>
      <td><b>${r.ch}</b></td>
      <td class="r num">${r.traffic?r.traffic.toLocaleString('uk'):'—'}</td>
      <td class="r num">${r.leads}</td>
      <td class="r"><span class="badge bb">${r.cr_tl?r.cr_tl+'%':'—'}</span></td>
      <td class="r num">${r.orders}</td>
      <td class="r"><span class="badge ${crLoBadge}">${r.cr_lo?r.cr_lo+'%':'—'}</span></td>
      <td class="r num">${r.budget_day?r.budget_day.toLocaleString('uk')+'₴':'—'}</td>
      <td class="r"><span class="badge ${drrBadge}">${r.drr?r.drr+'%':'—'}</span></td>
    </tr>`;
  }).join('');

  // Funnel chart (marketing)
  new Chart(document.getElementById('ch-funnel-mkt'),{
    type:'bar',
    data:{
      labels:['Matrasroll','Amebli','Sofino','DR-TV','Шоу-руми'],
      datasets:[
        {label:'Трафік/100',data:[42,28,16,0,0],backgroundColor:'rgba(51,154,240,0.4)',borderColor:'#339af0',borderWidth:1,borderRadius:3},
        {label:'Ліди',data:[140,105,48,8,19],backgroundColor:'rgba(162,155,254,0.7)',borderColor:'#a29bfe',borderWidth:1,borderRadius:3},
        {label:'Замовлення',data:[449,207,147,6,26],backgroundColor:'rgba(0,214,143,0.7)',borderColor:'#00d68f',borderWidth:1,borderRadius:3}
      ]
    },
    options:{
      responsive:true,maintainAspectRatio:false,
      plugins:{legend:{labels:{color:'#c1c7e0',font:{size:10},usePointStyle:true,boxWidth:8}},tooltip:TOOLTIP},
      scales:{x:{grid:GRID,ticks:{color:'#7b84a3',font:{size:9}}},y:{grid:GRID,ticks:{color:'#7b84a3'}}}
    }
  });

  // DRR trend
  new Chart(document.getElementById('ch-drr-trend'),{
    type:'line',
    data:{
      labels:['Квітень','Травень','1–4 Червня'],
      datasets:[
        {label:'ДРР Amebli %',data:[8,12,51.5],borderColor:'#ff6b6b',backgroundColor:'rgba(255,107,107,0.1)',tension:0.4,fill:true,pointRadius:5},
        {label:'ДРР Matrasroll %',data:[3,5,24.2],borderColor:'#ffa94d',backgroundColor:'rgba(255,169,77,0.1)',tension:0.4,fill:true,pointRadius:5},
        {label:'ДРР Загальний %',data:[1.7,2.3,10.07],borderColor:'#94d82d',backgroundColor:'rgba(148,216,45,0.1)',tension:0.4,fill:true,pointRadius:5}
      ]
    },
    options:{
      responsive:true,maintainAspectRatio:false,
      plugins:{legend:{labels:{color:'#c1c7e0',font:{size:10},usePointStyle:true,boxWidth:8}},tooltip:TOOLTIP},
      scales:{x:{grid:GRID,ticks:{color:'#7b84a3'}},y:{grid:GRID,ticks:{color:'#7b84a3',callback:v=>v+'%'}}}
    }
  });

  // Top pages
  const pages = [
    {page:'/ua/matrasy/',brand:'Matrasroll',traffic:320,cr_l:4.1,cr_o:2.8,rev:'148K'},
    {page:'/ua/divany/',brand:'Amebli',traffic:210,cr_l:3.5,cr_o:2.1,rev:'94K'},
    {page:'/ua/mattresses/',brand:'Matrasroll',traffic:180,cr_l:3.8,cr_o:2.5,rev:'67K'},
    {page:'/ua/krovati/',brand:'Sofino',traffic:165,cr_l:2.9,cr_o:1.8,rev:'49K'},
    {page:'/ua/toppery/',brand:'Amebli',traffic:145,cr_l:4.2,cr_o:3.1,rev:'45K'},
    {page:'/ua/podushky/',brand:'Matrasroll',traffic:120,cr_l:3.0,cr_o:2.2,rev:'41K'},
  ];
  document.getElementById('top-pages-tbody').innerHTML = pages.map((p,i)=>`
    <tr>
      <td class="num" style="color:var(--td)">${i+1}</td>
      <td style="font-family:'JetBrains Mono',monospace;font-size:10px">${p.page}</td>
      <td><span class="badge bb">${p.brand}</span></td>
      <td class="r num">${p.traffic}</td>
      <td class="r"><span class="badge bo">${p.cr_l}%</span></td>
      <td class="r"><span class="badge bg">${p.cr_o}%</span></td>
      <td class="r num" style="color:var(--g)">${p.rev}</td>
    </tr>`).join('');
}

// ═══════════ FINANCE CHARTS ═══════════
function initFinCharts() {
  recalcPL();
  new Chart(document.getElementById('ch-pl-monthly'),{
    type:'bar',
    data:{
      labels:['Квітень 2026','Травень 2026','Червень 2026\n(прогноз)'],
      datasets:[
        {label:'Виручка (1С)',data:[17377697,22639584,24000000],backgroundColor:['rgba(108,92,231,0.6)','rgba(108,92,231,0.6)','rgba(0,214,143,0.5)'],borderColor:['#a29bfe','#a29bfe','#00d68f'],borderWidth:1,borderRadius:4},
        {label:'Відгрузки',data:[15068035,16958769,10000000],backgroundColor:'rgba(255,169,77,0.4)',borderColor:'#ffa94d',borderWidth:1,borderRadius:4},
        {label:'Валова маржа 46%',type:'line',data:[8000000,10400000,11040000],borderColor:'#00d68f',backgroundColor:'transparent',tension:0.4,pointRadius:5,yAxisID:'y'}
      ]
    },
    options:{
      responsive:true,maintainAspectRatio:false,
      plugins:{legend:{labels:{color:'#c1c7e0',font:{size:10},usePointStyle:true,boxWidth:8}},tooltip:TOOLTIP},
      scales:{
        x:{grid:GRID,ticks:{color:'#7b84a3'}},
        y:{grid:GRID,ticks:{color:'#7b84a3',callback:v=>fmtK(v)+'₴'},position:'left'}
      }
    }
  });
}

// ═══════════ P&L RECALC ═══════════
function recalcPL() {
  const rev = +document.getElementById('fi-revenue').value||24000000;
  const cogsPct = (+document.getElementById('fi-cogs-pct').value||54)/100;
  const cogs = rev*cogsPct;
  const gross = rev-cogs;
  const sal = +document.getElementById('fi-salary').value||0;
  const rent = +document.getElementById('fi-rent').value||0;
  const ads = +document.getElementById('fi-ads').value||0;
  const log = +document.getElementById('fi-logistics').value||0;
  const ops = +document.getElementById('fi-ops').value||0;
  const oth = +document.getElementById('fi-other').value||0;
  const totalCosts = sal+rent+ads+log+ops+oth;
  const ebitda = gross-totalCosts;
  const margin = (ebitda/rev*100).toFixed(1);
  const drr = (ads/rev*100).toFixed(1);

  const c = v => v>=0 ? 'var(--g)' : 'var(--r)';
  const s = (id,val,color,prefix='') => {
    const el=document.getElementById(id);
    if(el){el.textContent=prefix+fmtN(Math.abs(val))+' ₴';if(color)el.style.color=color;}
  };
  s('pl-rev',rev,'var(--g)');
  s('pl-cogs',cogs,'var(--r)','−');
  s('pl-gross',gross,c(gross));
  s('pl-salary',sal,'var(--r)','−');
  s('pl-rent',rent,'var(--r)','−');
  s('pl-ads',ads,'var(--r)','−');
  s('pl-logistics',log,'var(--r)','−');
  s('pl-ops',ops,'var(--r)','−');
  s('pl-other',oth,'var(--r)','−');
  s('pl-total-costs',totalCosts,'var(--r)','−');
  const eEl=document.getElementById('pl-ebitda');
  if(eEl){eEl.textContent=fmtN(Math.abs(ebitda))+' ₴';eEl.style.color=c(ebitda);}
  const mEl=document.getElementById('pl-margin');if(mEl)mEl.textContent=margin+'%';
  const dEl=document.getElementById('pl-drr');if(dEl){dEl.textContent=drr+'%';dEl.style.color=+drr<=7?'var(--g)':+drr<=15?'var(--o)':'var(--r)';}

  // Update KPI cards
  const kRev=document.getElementById('fin-kpi-rev');if(kRev)kRev.innerHTML='~'+fmtK(rev)+'<span class="ku">₴</span>';
  const kGross=document.getElementById('fin-kpi-gross');if(kGross)kGross.innerHTML='~'+fmtK(gross)+'<span class="ku">₴</span>';
  const kEbitda=document.getElementById('fin-kpi-ebitda');if(kEbitda)kEbitda.innerHTML='~'+fmtK(ebitda)+'<span class="ku">₴</span>';
  const kMl=document.getElementById('fin-kpi-margin-lbl');if(kMl)kMl.textContent='~'+margin+'%';

  // Scenario base
  const sb=document.getElementById('scenario-base-ebitda');if(sb)sb.textContent=(ebitda/1e6).toFixed(2)+'M₴';
  const sm=document.getElementById('scenario-base-margin');if(sm)sm.textContent=margin+'%';
}

// ═══════════ FEEDBACK BUTTONS + MODAL ═══════════
let fbCurrentModule='';
function makeFbBtn(name){
  const b=document.createElement('button');
  b.className='fb-btn';
  b.dataset.mod=name||'Модуль';
  b.innerHTML='<i>💬</i> Скажи як покращити';
  b.title='Некоректні цифри? Незручно? Напиши — виправимо';
  b.onclick=function(e){e.stopPropagation();openFeedback(name);};
  return b;
}
function injectFbButtons(){
  // Section headers (overview modules)
  document.querySelectorAll('.sec-head').forEach(h=>{
    const name=(h.querySelector('.sec-title')||{}).textContent || 'Модуль';
    const b=makeFbBtn(name.trim()); b.style.marginLeft='12px'; h.appendChild(b);
  });
  // MCI bar
  document.querySelectorAll('.mci-bar').forEach(m=>{
    const b=makeFbBtn('MCI індекс'); b.style.position='absolute'; b.style.top='8px'; b.style.right='10px'; m.appendChild(b);
  });
  // Cards with their own title (sub-modules in all tabs)
  document.querySelectorAll('.cd .ct').forEach(ct=>{
    let name=ct.textContent.replace(/∑.*$/,'').trim()||'Модуль';
    const b=makeFbBtn(name);
    const badge=ct.querySelector('.btot');
    b.style.marginLeft = badge ? '8px' : 'auto';
    ct.appendChild(b);
  });
}
function openFeedback(name){
  fbCurrentModule=name||'Модуль';
  document.getElementById('fbModName').textContent='Модуль: '+fbCurrentModule;
  document.getElementById('fbText').value='';
  document.getElementById('fbForm').style.display='block';
  document.getElementById('fbOk').style.display='none';
  document.getElementById('fbOverlay').classList.add('on');
  document.getElementById('fbText').focus();
}
function closeFeedback(){document.getElementById('fbOverlay').classList.remove('on');}
function submitFeedback(){
  const text=document.getElementById('fbText').value.trim();
  if(!text){document.getElementById('fbText').focus();return;}
  const payload={
    module:fbCurrentModule,
    text:text,
    tab:(document.querySelector('.mtab.on')||{}).textContent||'',
    ts:new Date().toISOString()
  };
  // TODO(backend): POST payload -> Telegram bot. Зараз заглушка:
  console.log('FEEDBACK → Telegram (stub):', payload);
  /*
  fetch('/api/feedback',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(payload)});
  */
  document.getElementById('fbForm').style.display='none';
  document.getElementById('fbOk').style.display='block';
  setTimeout(closeFeedback,1500);
}
document.addEventListener('keydown',e=>{if(e.key==='Escape'){closeFeedback();closeDate();}});
injectFbButtons();

// ═══════════ DATE / PERIOD CONTROLS ═══════════
let dtCurrentBtn=null;
function toggleGlobalCustom(){
  document.getElementById('gpCustom').style.display = document.getElementById('globalPeriod').value==='custom'?'inline-flex':'none';
  document.getElementById('gcCustom').style.display = document.getElementById('globalCompare').value==='custom'?'inline-flex':'none';
}
function applyGlobalPeriod(){
  const p=document.getElementById('globalPeriod');
  const c=document.getElementById('globalCompare');
  let pTxt;
  if(p.value==='custom'){const f=document.getElementById('gpFrom').value,t=document.getElementById('gpTo').value;pTxt=(f||'?')+'–'+(t||'?');}
  else pTxt=p.options[p.selectedIndex].text.replace(/\s*\(.*\)/,'');
  let cTxt;
  if(c.value==='none')cTxt='без порівняння';
  else if(c.value==='custom'){const f=document.getElementById('gcFrom').value,t=document.getElementById('gcTo').value;cTxt='vs '+(f||'?')+'–'+(t||'?');}
  else cTxt='vs '+c.options[c.selectedIndex].text.replace(/\s*\(.*\)/,'');
  document.getElementById('pbHint').textContent=pTxt+' · '+cTxt;
  // TODO(backend): перезавантажити дані дашборда під обраний період/порівняння
  console.log('GLOBAL PERIOD (stub):',{
    period:p.value, periodFrom:(document.getElementById('gpFrom')||{}).value, periodTo:(document.getElementById('gpTo')||{}).value,
    compare:c.value, compareFrom:(document.getElementById('gcFrom')||{}).value, compareTo:(document.getElementById('gcTo')||{}).value
  });
}
function makeDtBtn(name){
  const b=document.createElement('button');
  b.className='fb-btn dt-btn';
  b.dataset.mod=name||'Модуль';
  b.innerHTML='<i>📅</i> <span class="dt-lbl">Червень · vs Травень</span>';
  b.title='Обрати період та місяць порівняння для цього модуля';
  b.onclick=function(e){e.stopPropagation();openDate(name,b);};
  return b;
}
function injectDateButtons(){
  document.querySelectorAll('.fb-btn:not(.dt-btn)').forEach(fb=>{
    const dt=makeDtBtn(fb.dataset.mod||'Модуль');
    dt.style.marginLeft=fb.style.marginLeft;
    if(fb.style.marginLeft==='auto'){fb.style.marginLeft='8px';}
    if(fb.style.position==='absolute'){
      dt.style.position='absolute'; dt.style.top=fb.style.top; dt.style.right='128px';
      fb.parentNode.appendChild(dt);
    } else {
      fb.parentNode.insertBefore(dt, fb);
    }
  });
}
function injectButtonsIn(root){
  if(!root)return;
  root.querySelectorAll('.cd .ct').forEach(ct=>{
    if(ct.querySelector('.fb-btn'))return;
    let name=ct.textContent.replace(/∑.*$/,'').trim()||'Модуль';
    const fb=makeFbBtn(name);
    const badge=ct.querySelector('.btot');
    fb.style.marginLeft=badge?'8px':'auto';
    const dt=makeDtBtn(name);
    dt.style.marginLeft=fb.style.marginLeft;
    if(fb.style.marginLeft==='auto')fb.style.marginLeft='8px';
    ct.appendChild(dt);ct.appendChild(fb);
  });
}
function openDate(name, btn){
  dtCurrentBtn=btn||null;
  document.getElementById('dtModName').textContent='Модуль: '+(name||'Модуль');
  document.getElementById('dtOverlay').classList.add('on');
}
function closeDate(){document.getElementById('dtOverlay').classList.remove('on');}
function toggleCustomRange(){
  document.getElementById('dtCustom').style.display = document.getElementById('dtPeriod').value==='custom' ? 'flex' : 'none';
  document.getElementById('cmpCustom').style.display = document.getElementById('dtCompare').value==='custom' ? 'flex' : 'none';
}
function applyDate(){
  const p=document.getElementById('dtPeriod');
  const c=document.getElementById('dtCompare');
  let pTxt=p.options[p.selectedIndex].text.replace(/\s*\(.*\)/,'').replace(' 2026','');
  if(p.value==='custom'){
    const f=document.getElementById('dtFrom').value, t=document.getElementById('dtTo').value;
    pTxt=(f||'?')+'–'+(t||'?');
  }
  let cTxt;
  if(c.value==='none'){cTxt='без порівн.';}
  else if(c.value==='custom'){
    const f=document.getElementById('cmpFrom').value, t=document.getElementById('cmpTo').value;
    cTxt='vs '+(f||'?')+'–'+(t||'?');
  } else {
    cTxt='vs '+c.options[c.selectedIndex].text.replace(/\s*\(.*\)/,'').replace(' 2026','');
  }
  if(dtCurrentBtn){const lbl=dtCurrentBtn.querySelector('.dt-lbl');if(lbl)lbl.textContent=pTxt+' · '+cTxt;}
  // TODO(backend): перезавантажити цей модуль під обраний період/порівняння
  console.log('MODULE PERIOD (stub):',{
    module:(dtCurrentBtn||{}).dataset?.mod,
    period:p.value, periodFrom:document.getElementById('dtFrom').value, periodTo:document.getElementById('dtTo').value,
    compare:c.value, compareFrom:document.getElementById('cmpFrom').value, compareTo:document.getElementById('cmpTo').value
  });
  closeDate();
}
injectDateButtons();
</script>
</body>
</html>
